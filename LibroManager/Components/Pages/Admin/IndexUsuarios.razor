@page "/admin/usuarios"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using LibroManager.Models
@using LibroManager.Constants
@using LibroManager.Services.Interfaces
@using System.ComponentModel.DataAnnotations
@using LibroManager.Components.Pages.Admin.Dialogs
@inject IUserService UserService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@attribute [Authorize(Policy = RoleConstants.Permissions.Users.ManageUsers)]
@rendermode InteractiveServer

<PageTitle>Gestión de Usuarios - LibroManager</PageTitle>
<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<div class="ma-4" style="height: calc(100vh - 140px); display: flex; flex-direction: column;">
    <div class="d-flex justify-space-between align-center mb-4">
        <MudText Typo="Typo.h4">Gestión de Usuarios</MudText>
        <MudButton Color="Color.Primary" StartIcon="@Icons.Material.Filled.PersonAdd" Variant="Variant.Filled" OnClick="MostrarModalCrearUsuario">
            Nuevo Usuario
        </MudButton>
    </div>

    @if (_usuarios == null)
    {
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    }
    else
    {
        <MudTable Items="@_usuarios" Dense="true" Hover="true" Filter="FiltrarUsuarios"
                  T="ApplicationUser" Elevation="0" Class="flex-grow-1" FixedHeader="true">
            <ToolBarContent>
                <MudTextField @bind-Value="_searchString" Placeholder="Buscar..." Adornment="Adornment.Start"
                            AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" Immediate="true" />
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel T="ApplicationUser" SortBy="x => x.Email">Email</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel T="ApplicationUser" SortBy="x => x.NombreCompleto">Nombre</MudTableSortLabel></MudTh>
                <MudTh>Rol</MudTh>
                <MudTh>Acciones</MudTh>
            </HeaderContent>
            <RowTemplate Context="usuario">
                <MudTd DataLabel="Email">@usuario.Email</MudTd>
                <MudTd DataLabel="Nombre">@usuario.NombreCompleto</MudTd>
                <MudTd DataLabel="Rol">
                    <MudChip T="string" Color="@(EsUsuarioAdmin(usuario) ? Color.Primary : Color.Info)" Size="Size.Small">
                        @(EsUsuarioAdmin(usuario) ? "Administrador" : "Bibliotecario")
                    </MudChip>
                </MudTd>
                <MudTd>
                    <MudStack Row="true" Spacing="1">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Warning" Size="Size.Small"
                                     OnClick="@(() => EditarUsuario(usuario))" aria-label="Editar usuario" />
                        @if (!EsUsuarioAdmin(usuario))
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                         OnClick="@(() => EliminarUsuario(usuario))" aria-label="Eliminar usuario" />
                        }
                    </MudStack>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager RowsPerPageString="Filas por página" />
            </PagerContent>
        </MudTable>
    }
</div>

@code {
    private List<ApplicationUser>? _usuarios;
    private Dictionary<string, List<string>> _usuariosRoles = new();
    private string _searchString = "";

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        try
        {
            _usuarios = (await UserService.GetAllUsersAsync()).ToList();
            _usuariosRoles = await UserService.GetAllUsersWithRolesAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al cargar los datos: {ex.Message}", Severity.Error);
        }
    }

    private async Task MostrarModalCrearUsuario()
    {
        var nuevoUsuario = new CrearUsuarioDialog.NuevoUsuarioModel { Role = RoleConstants.LibrarianRole };
        
        var parametros = new DialogParameters
        {
            ["NuevoUsuario"] = nuevoUsuario
        };
        
        var opciones = new DialogOptions 
        { 
            MaxWidth = MaxWidth.Medium,
            CloseButton = true,
            FullWidth = true,
            NoHeader = false
        };
        
        var dialog = await DialogService.ShowAsync<CrearUsuarioDialog>("Crear Usuario", parametros, opciones);
        var resultado = await dialog.Result;
        
        if (resultado is { Canceled: false, Data: true })
        {
            await CargarDatos();
        }
    }

    private async Task EditarUsuario(ApplicationUser usuario)
    {
        var usuarioEditar = new ApplicationUser
        {
            Id = usuario.Id,
            UserName = usuario.UserName,
            Email = usuario.Email,
            NombreCompleto = usuario.NombreCompleto,
            EmailConfirmed = usuario.EmailConfirmed,
            FechaCreacion = usuario.FechaCreacion
        };
        
        var roles = _usuariosRoles.GetValueOrDefault(usuario.Id, new List<string>());
        var rolEditar = roles.Contains(RoleConstants.AdminRole) ? RoleConstants.AdminRole : RoleConstants.LibrarianRole;
        var esAdmin = roles.Contains(RoleConstants.AdminRole);
        
        var parametros = new DialogParameters
        {
            ["Usuario"] = usuarioEditar,
            ["Rol"] = rolEditar,
            ["IsAdmin"] = esAdmin
        };
        
        var opciones = new DialogOptions 
        { 
            MaxWidth = MaxWidth.Medium,
            CloseButton = true,
            FullWidth = true,
            NoHeader = false
        };
        
        var dialog = await DialogService.ShowAsync<EditarUsuarioDialog>("Editar Usuario", parametros, opciones);
        var resultado = await dialog.Result;
        
        if (resultado is { Canceled: false, Data: true })
        {
            await CargarDatos();
        }
    }

    private async Task EliminarUsuario(ApplicationUser usuario)
    {
        bool? resultado = await DialogService.ShowMessageBox(
            "Confirmar Eliminación",
            $"¿Está seguro que desea eliminar al usuario {usuario.Email}?",
            yesText: "Eliminar", 
            noText: "Cancelar",
            options: new DialogOptions { MaxWidth = MaxWidth.ExtraSmall }
        );

        if (resultado == true)
        {
            try
            {
                var result = await UserService.DeleteUserAsync(usuario.Id);
                if (result.Succeeded)
                {
                    await CargarDatos();
                    Snackbar.Add("Usuario eliminado exitosamente", Severity.Success);
                }
                else
                {
                    Snackbar.Add(string.Join(", ", result.Errors.Select(e => e.Description)), Severity.Error);
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error al eliminar el usuario: {ex.Message}", Severity.Error);
            }
        }
    }

    private bool FiltrarUsuarios(ApplicationUser usuario)
    {
        if (string.IsNullOrWhiteSpace(_searchString)) return true;
        return usuario.Email?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) == true
            || usuario.NombreCompleto?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) == true;
    }

    private bool EsUsuarioAdmin(ApplicationUser user)
    {
        var roles = _usuariosRoles.GetValueOrDefault(user.Id, new List<string>());
        return roles.Contains(RoleConstants.AdminRole);
    }
}