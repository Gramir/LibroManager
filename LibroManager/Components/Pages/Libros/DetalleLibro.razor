@page "/libros/{LibroId:int}"
@using Microsoft.AspNetCore.Authorization
@using LibroManager.Services.Interfaces
@using LibroManager.DTOs
@using LibroManager.Constants
@using LibroManager.Models

@attribute [Authorize(Policy = RoleConstants.Permissions.Libros.Read)]
@rendermode InteractiveServer
<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<HeadContent>
    <title>Detalle del Libro</title>
</HeadContent>

<style>
    .dropdown-container {
        position: relative;
    }
    .dropdown-menu {
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        z-index: 1000;
        display: none;
        max-height: 200px;
        overflow-y: auto;
        padding: 0.5rem 0;
        margin: 0;
        background-color: #fff;
        border: 1px solid rgba(0,0,0,.15);
        border-radius: 0.25rem;
    }
    .dropdown-menu.show {
        display: block;
    }
    .dropdown-item {
        display: block;
        width: 100%;
        padding: 0.25rem 1rem;
        clear: both;
        font-weight: 400;
        color: #212529;
        text-align: inherit;
        text-decoration: none;
        white-space: nowrap;
        background-color: transparent;
        border: 0;
    }
    .dropdown-item:hover {
        background-color: #f8f9fa;
        cursor: pointer;
    }
</style>

<div class="container mt-4">
    @if (_libro == null)
    {
        <div class="d-flex justify-content-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h3 class="mb-0">@_libro.Titulo</h3>
                <div>
                    <AuthorizeView Policy="@RoleConstants.Permissions.Libros.Update">
                        <Authorized>
                            <button class="btn btn-warning me-2" @onclick="EditarLibro">Editar</button>
                        </Authorized>
                    </AuthorizeView>
                    <button class="btn btn-secondary" @onclick="Volver">Volver</button>
                </div>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <dl class="row">
                            <dt class="col-sm-4">ISBN:</dt>
                            <dd class="col-sm-8">@_libro.ISBN</dd>

                            <dt class="col-sm-4">Autor:</dt>
                            <dd class="col-sm-8">@_libro.AutorNombre</dd>

                            <dt class="col-sm-4">Categoría:</dt>
                            <dd class="col-sm-8">@_libro.CategoriaNombre</dd>

                            <dt class="col-sm-4">Ejemplares:</dt>
                            <dd class="col-sm-8">@_ejemplares.Count()</dd>
                        </dl>
                    </div>
                </div>

                @if (_ejemplares.Any())
                {
                    <div class="mt-4">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h4>Lista de Ejemplares</h4>
                            <AuthorizeView Policy="@RoleConstants.Permissions.Libros.Create">
                                <Authorized>
                                    <button class="btn btn-primary" @onclick="MostrarFormularioEjemplar">
                                        <i class="bi bi-plus-circle"></i> Crear Ejemplar
                                    </button>
                                </Authorized>
                            </AuthorizeView>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-striped">
                                <thead>
                                    <tr>
                                        <th>Serial</th>
                                        <th>Ubicación</th>
                                        <th>Estado</th>
                                        <th>Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var ejemplar in _ejemplares.OrderBy(e => e.Serial))
                                    {
                                        <tr>
                                            <td>@ejemplar.Serial</td>
                                            <td>@ejemplar.UbicacionFormateada</td>
                                            <td>
                                                <span class="badge @GetEstadoBadgeClass(ejemplar)">
                                                    @GetEstadoText(ejemplar)
                                                </span>
                                            </td>
                                            <td>
                                                @if (ejemplar.EstaPrestado || ejemplar.EstaPerdido)
                                                {
                                                    <AuthorizeView Policy="@RoleConstants.Permissions.Prestamos.Read">
                                                        <Authorized>
                                                            <button class="btn btn-info btn-sm me-2" @onclick="() => VerPrestamo(ejemplar.LibroId)">
                                                                <i class="bi bi-eye"></i> Ver préstamo
                                                            </button>
                                                        </Authorized>
                                                    </AuthorizeView>
                                                }
                                                @if (!ejemplar.EstaPrestado && !ejemplar.EstaPerdido)
                                                {
                                                    <AuthorizeView Policy="@RoleConstants.Permissions.Prestamos.Create">
                                                        <Authorized>
                                                            <button class="btn btn-success btn-sm me-2" @onclick="() => PrestarLibro(ejemplar.LibroId)">
                                                                <i class="bi bi-book"></i> Prestar
                                                            </button>
                                                        </Authorized>
                                                    </AuthorizeView>
                                                }
                                                <AuthorizeView Policy="@RoleConstants.Permissions.Libros.Update">
                                                    <Authorized>
                                                        <button class="btn btn-warning btn-sm me-2" @onclick="() => MostrarFormularioEditarEjemplar(ejemplar)"
                                                                disabled="@ejemplar.EstaPrestado">
                                                            <i class="bi bi-pencil"></i> Editar
                                                        </button>
                                                    </Authorized>
                                                </AuthorizeView>
                                                <AuthorizeView Policy="@RoleConstants.Permissions.Libros.Delete">
                                                    <Authorized>
                                                        <button class="btn btn-danger btn-sm" @onclick="() => MostrarConfirmacionEjemplar(ejemplar)"
                                                                disabled="@ejemplar.EstaPrestado">
                                                            <i class="bi bi-trash"></i> Eliminar
                                                        </button>
                                                    </Authorized>
                                                </AuthorizeView>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
                else
                {
                    <div class="mt-4">
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle"></i> No hay ejemplares registrados para este libro.
                        </div>
                        <AuthorizeView Policy="@RoleConstants.Permissions.Libros.Create">
                            <Authorized>
                                <button class="btn btn-primary" @onclick="MostrarFormularioEjemplar">
                                    <i class="bi bi-plus-circle"></i> Crear Ejemplar
                                </button>
                            </Authorized>
                        </AuthorizeView>
                    </div>
                }
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger mt-3">
            @_errorMessage
        </div>
    }
</div>

@if (_mostrarFormularioEjemplar)
{
    <div class="modal fade show" style="display: block;" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Crear Nuevo Ejemplar</h5>
                    <button type="button" class="btn-close" @onclick="CerrarFormularioEjemplar"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Título del Libro</label>
                        <input type="text" class="form-control" value="@_libro?.Titulo" readonly />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">ISBN</label>
                        <input type="text" class="form-control" value="@_libro?.ISBN" readonly />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Serial a Asignar</label>
                        <input type="text" class="form-control" value="@_proximoSerial" readonly />
                    </div>
                    <div class="mb-3 dropdown-container" @onclick:stopPropagation>
                        <label for="ubicacion" class="form-label">Ubicación</label>
                        <div class="input-group">
                            <input type="text" 
                                   class="form-control" 
                                   id="ubicacion" 
                                   value="@_nuevaUbicacion"
                                   @oninput="@(e => OnUbicacionInput(e))"
                                   @onfocus="ShowDropdown"
                                   @onblur="async () => await OnBlur()"
                                   placeholder="Escriba para filtrar ubicaciones..." />
                        </div>
                        <div class="dropdown-menu @(_showDropdown ? "show" : "")">
                            @if (_ubicacionesFiltradas != null && _ubicacionesFiltradas.Any())
                            {
                                @foreach (var ubicacion in _ubicacionesFiltradas)
                                {
                                    <div class="dropdown-item" 
                                         @onmousedown="@(() => SelectUbicacion(ubicacion.UbicacionFormateada))">
                                        @ubicacion.UbicacionFormateada
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="dropdown-item">No se encontraron ubicaciones</div>
                            }
                        </div>
                        @if (_ubicaciones != null && !_ubicaciones.Any())
                        {
                            <div class="alert alert-warning mt-2">
                                No hay ubicaciones disponibles. Por favor, libere alguna ubicación antes de agregar un nuevo ejemplar.
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(_errorMessageUbicacion))
                        {
                            <div class="alert alert-danger mt-2">
                                @_errorMessageUbicacion
                            </div>
                        }
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CerrarFormularioEjemplar">Cancelar</button>
                    <button type="button" class="btn btn-primary" @onclick="CrearEjemplar" disabled="@string.IsNullOrWhiteSpace(_nuevaUbicacion)">
                        Crear
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@if (_mostrarFormularioEditarEjemplar)
{
    <div class="modal fade show" style="display: block;" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Editar Ejemplar</h5>
                    <button type="button" class="btn-close" @onclick="CerrarFormularioEditarEjemplar"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Título del Libro</label>
                        <input type="text" class="form-control" value="@_libro?.Titulo" readonly />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">ISBN</label>
                        <input type="text" class="form-control" value="@_libro?.ISBN" readonly />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Serial</label>
                        <input type="text" class="form-control" value="@(_ejemplarEditar?.Serial)" readonly />
                    </div>
                    <div class="mb-3 dropdown-container" @onclick:stopPropagation>
                        <label for="ubicacionEdit" class="form-label">Ubicación</label>
                        <div class="input-group">
                            <input type="text" 
                                   class="form-control" 
                                   id="ubicacionEdit" 
                                   value="@_nuevaUbicacion"
                                   @oninput="@(e => OnUbicacionInput(e))"
                                   @onfocus="ShowDropdown"
                                   @onblur="async () => await OnBlur()"
                                   placeholder="Escriba para filtrar ubicaciones..." />
                        </div>
                        <div class="dropdown-menu @(_showDropdown ? "show" : "")">
                            @if (_ubicacionesFiltradas != null && _ubicacionesFiltradas.Any())
                            {
                                @foreach (var ubicacion in _ubicacionesFiltradas)
                                {
                                    <div class="dropdown-item" 
                                         @onmousedown="@(() => SelectUbicacion(ubicacion.UbicacionFormateada))">
                                        @ubicacion.UbicacionFormateada
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="dropdown-item">No se encontraron ubicaciones</div>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(_errorMessageUbicacion))
                        {
                            <div class="alert alert-danger mt-2">
                                @_errorMessageUbicacion
                            </div>
                        }
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CerrarFormularioEditarEjemplar">Cancelar</button>
                    <button type="button" class="btn btn-primary" @onclick="GuardarEjemplar" disabled="@string.IsNullOrWhiteSpace(_nuevaUbicacion)">
                        Guardar
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@if (_mostrarConfirmacion)
{
    <div class="modal fade show" style="display: block;" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirmar eliminación</h5>
                    <button type="button" class="btn-close" @onclick="CancelarEliminacion"></button>
                </div>
                <div class="modal-body">
                    @if (_ejemplarAEliminar != null)
                    {
                        <p>¿Está seguro que desea eliminar el ejemplar con serial '@_ejemplarAEliminar.Serial'?</p>
                        @if (_tienePrestamosHistoricos)
                        {
                            <div class="alert alert-warning">
                                <i class="bi bi-exclamation-triangle"></i>
                                Este ejemplar tiene historial de préstamos. Al eliminarlo, se eliminarán también todos los préstamos históricos asociados.
                            </div>
                        }
                        @if (_ejemplares.Count() == 1)
                        {
                            <div class="alert alert-warning">
                                <i class="bi bi-exclamation-triangle"></i>
                                Este es el último ejemplar del libro. Al eliminarlo, se eliminará también toda la información del libro.
                            </div>
                        }
                    }
                    else
                    {
                        <p>¿Está seguro que desea eliminar el libro '@_libro?.Titulo' y todos sus ejemplares?</p>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CancelarEliminacion">Cancelar</button>
                    <button type="button" class="btn btn-danger" @onclick="EliminarLibro">Confirmar</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}
