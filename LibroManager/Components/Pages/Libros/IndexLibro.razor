@page "/libros"
@using Microsoft.AspNetCore.Authorization
@using LibroManager.Services.Interfaces
@using LibroManager.DTOs
@using LibroManager.Constants
@inject ILibroService LibroService
@inject NavigationManager NavigationManager
@attribute [Authorize(Policy = RoleConstants.Permissions.Libros.Read)]
@rendermode InteractiveServer

<PageTitle>Libros - LibroManager</PageTitle>
<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider /> 
<MudSnackbarProvider />
<div class="ma-4" style="height: calc(100vh - 140px); display: flex; flex-direction: column;">
    <div class="d-flex justify-space-between align-center mb-4">
        <MudText Typo="Typo.h4">Catálogo de Libros</MudText>
        <AuthorizeView Policy="@RoleConstants.Permissions.Libros.Create">
            <Authorized>
                <MudButton Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" OnClick="CrearLibro">
                    Crear Libro
                </MudButton>
            </Authorized>
        </AuthorizeView>
    </div>

    @if (libros == null)
    {
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    }
    else
    {
        <MudTable Items="@librosUnicos" Dense="true" Hover="true" Filter="FiltrarLibros"
                  T="LibroDTO" Elevation="0" Class="flex-grow-1" FixedHeader="true">
            <ToolBarContent>
                <MudTextField @bind-Value="_searchString" Placeholder="Buscar..." Adornment="Adornment.Start"
                            AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" Immediate="true"></MudTextField>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel T="LibroDTO" SortBy="x => x.Titulo">Título</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel T="LibroDTO" SortBy="x => x.ISBN">ISBN</MudTableSortLabel></MudTh>
                <MudTh>Ejemplares</MudTh>
                <MudTh><MudTableSortLabel T="LibroDTO" SortBy="x => x.AutorNombre">Autor</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel T="LibroDTO" SortBy="x => x.CategoriaNombre">Categoría</MudTableSortLabel></MudTh>
                <MudTh>Acciones</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Título">@context.Titulo</MudTd>
                <MudTd DataLabel="ISBN">@context.ISBN</MudTd>
                <MudTd DataLabel="Ejemplares">
                    @{
                        var totalEjemplares = ejemplaresPorIsbn.TryGetValue(context.ISBN, out var count) ? count : 0;
                        var prestados = ejemplaresPrestadosPorIsbn.TryGetValue(context.ISBN, out var prestadosCount) ? prestadosCount : 0;
                        var perdidos = ejemplaresPerdidosPorIsbn.TryGetValue(context.ISBN, out var perdidosCount) ? perdidosCount : 0;
                        var disponibles = totalEjemplares - prestados - perdidos;
                        var colorClass = disponibles > 0 ? Color.Success : Color.Error;
                    }
                    <MudStack Row="true" Spacing="1">
                        <MudChip T="string" Color="@colorClass" Size="Size.Small">@disponibles disponibles</MudChip>
                        <MudChip T="string" Color="@(prestados > 0 ? Color.Warning : Color.Default)" Size="Size.Small">@prestados prestados</MudChip>
                        <MudChip T="string" Color="@(perdidos > 0 ? Color.Error : Color.Default)" Size="Size.Small">@perdidos perdidos</MudChip>
                        <MudChip T="string" Color="Color.Default" Size="Size.Small">@totalEjemplares total</MudChip>
                    </MudStack>
                </MudTd>
                <MudTd DataLabel="Autor">@context.AutorNombre</MudTd>
                <MudTd DataLabel="Categoría">@context.CategoriaNombre</MudTd>
                <MudTd>
                    <MudStack Row="true" Spacing="1">
                        <AuthorizeView Policy="@RoleConstants.Permissions.Libros.Read">
                            <Authorized Context="authView">
                                <MudIconButton Icon="@Icons.Material.Filled.Visibility" Color="Color.Primary" Size="Size.Small"
                                             OnClick="@(() => VerDetalles(context.LibroId))" 
                                             aria-label="Ver detalles" />
                            </Authorized>
                        </AuthorizeView>
                        <AuthorizeView Policy="@RoleConstants.Permissions.Libros.Update">
                            <Authorized Context="authEdit">
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Warning" Size="Size.Small"
                                             OnClick="@(() => EditarLibro(context.LibroId))" 
                                             aria-label="Editar libro" />
                            </Authorized>
                        </AuthorizeView>
                        @{
                            var disponibleParaPrestamo = ejemplaresPorIsbn.TryGetValue(context.ISBN, out var total) &&
                                                      ejemplaresPrestadosPorIsbn.TryGetValue(context.ISBN, out var prest) &&
                                                      ejemplaresPerdidosPorIsbn.TryGetValue(context.ISBN, out var perd) &&
                                                      (total - prest - perd) > 0;
                        }
                        <AuthorizeView Policy="@RoleConstants.Permissions.Prestamos.Create">
                            <Authorized Context="authLoan">
                                <MudIconButton Icon="@Icons.Material.Filled.Book" Color="Color.Success" Size="Size.Small"
                                             OnClick="@(() => PrestarLibro(context.LibroId))" 
                                             Disabled="@(!disponibleParaPrestamo)"
                                             aria-label="Prestar libro" />
                            </Authorized>
                        </AuthorizeView>
                    </MudStack>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager RowsPerPageString="Filas por página" />
            </PagerContent>
        </MudTable>
    }
</div>

@code {
    private List<LibroDTO>? libros;
    private List<LibroDTO> librosUnicos = new();
    private Dictionary<string, int> ejemplaresPorIsbn = new();
    private Dictionary<string, int> ejemplaresPrestadosPorIsbn = new();
    private Dictionary<string, int> ejemplaresPerdidosPorIsbn = new();
    private string _searchString = "";

    protected override async Task OnInitializedAsync()
    {
        libros = (await LibroService.GetAllLibrosAsync()).ToList();
        if (libros != null)
        {
            librosUnicos = libros.GroupBy(l => l.ISBN)
                                .Select(g => g.First())
                                .ToList();
        }
        await CargarNumeroEjemplares();
    }

    private async Task CargarNumeroEjemplares()
    {
        if (libros == null) return;
        
        var isbnsUnicos = libros.Select(l => l.ISBN).Distinct();
        
        foreach (var isbn in isbnsUnicos)
        {
            var count = await LibroService.ContarEjemplaresPorIsbnAsync(isbn);
            ejemplaresPorIsbn[isbn] = count;
            
            var prestados = await LibroService.ContarEjemplaresPrestadosPorIsbnAsync(isbn);
            ejemplaresPrestadosPorIsbn[isbn] = prestados;

            var perdidos = await LibroService.ContarEjemplaresPerdidosPorIsbnAsync(isbn);
            ejemplaresPerdidosPorIsbn[isbn] = perdidos;
        }
    }

    private void VerDetalles(int libroId)
    {
        NavigationManager.NavigateTo($"/libros/{libroId}");
    }

    private void CrearLibro()
    {
        NavigationManager.NavigateTo("/libros/crear");
    }

    private void EditarLibro(int libroId)
    {
        NavigationManager.NavigateTo($"/libros/editar/{libroId}");
    }

    private void PrestarLibro(int libroId)
    {
        var libro = libros?.FirstOrDefault(l => l.LibroId == libroId);
        if (libro == null) return;

        var ejemplarDisponible = libros?.FirstOrDefault(l => 
            l.ISBN == libro.ISBN && 
            !l.EstaPrestado);

        if (ejemplarDisponible != null)
        {
            NavigationManager.NavigateTo($"/prestamos/crear/{ejemplarDisponible.LibroId}");
        }
    }

    private bool FiltrarLibros(LibroDTO libro)
    {
        if (string.IsNullOrWhiteSpace(_searchString)) return true;
        
        return libro.Titulo?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) == true ||
               libro.ISBN?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) == true ||
               libro.AutorNombre?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) == true ||
               libro.CategoriaNombre?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) == true;
    }
}