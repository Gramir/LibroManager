@page "/autores/{AutorId:int}"
@using Microsoft.AspNetCore.Authorization
@using LibroManager.DTOs
@using LibroManager.Services.Interfaces
@using LibroManager.Constants
@inject IAutorService AutorService
@inject ILibroService LibroService
@inject NavigationManager NavigationManager
@attribute [Authorize(Policy = RoleConstants.Permissions.Autores.Read)]
@rendermode InteractiveServer
<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<PageTitle>Detalle del Autor</PageTitle>

<div class="container mt-4">
    @if (_autor == null)
    {
        <div class="d-flex justify-content-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h3 class="mb-0">@_autor.Nombre</h3>
                <div>
                    <button class="btn btn-secondary me-2" @onclick="Volver">Volver</button>
                    <AuthorizeView Policy="@RoleConstants.Permissions.Autores.Update">
                        <Authorized>
                            <button class="btn btn-warning me-2" @onclick="EditarAutor">Editar</button>
                        </Authorized>
                    </AuthorizeView>
                    <AuthorizeView Policy="@RoleConstants.Permissions.Autores.Delete">
                        <Authorized>
                            <button class="btn btn-danger" @onclick="MostrarConfirmacion" disabled="@(_autor.CantidadLibros > 0)">
                                Eliminar
                            </button>
                            @if (_autor.CantidadLibros > 0)
                            {
                                <div class="text-danger mt-2 small">
                                    <i class="bi bi-exclamation-circle"></i> No se puede eliminar un autor que tiene libros asociados
                                </div>
                            }
                        </Authorized>
                    </AuthorizeView>
                </div>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <dl class="row">
                            <dt class="col-sm-4">Cantidad de Libros:</dt>
                            <dd class="col-sm-8">@_libros.Count()</dd>
                        </dl>
                    </div>
                </div>

                @if (_libros.Any())
                {
                    <div class="mt-4">
                        <h4>Libros del Autor</h4>
                        <div class="table-responsive">
                            <table class="table">
                                <thead>
                                    <tr>
                                        <th>Título</th>
                                        <th>ISBN</th>
                                        <th>Categoría</th>
                                        <th>Ejemplares</th>
                                        <th>Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var libro in _libros)
                                    {
                                        var totalEjemplares = ejemplaresPorIsbn.TryGetValue(libro.ISBN, out var count) ? count : 0;
                                        var prestados = ejemplaresPrestadosPorIsbn.TryGetValue(libro.ISBN, out var prestadosCount) ? prestadosCount : 0;
                                        var perdidos = ejemplaresPerdidosPorIsbn.TryGetValue(libro.ISBN, out var perdidosCount) ? perdidosCount : 0;
                                        var disponibles = totalEjemplares - prestados - perdidos;
                                        var colorClass = disponibles > 0 ? "text-success" : "text-danger";

                                        <tr>
                                            <td>@libro.Titulo</td>
                                            <td>@libro.ISBN</td>
                                            <td>@libro.CategoriaNombre</td>
                                            <td class="@colorClass">
                                                <strong>@disponibles</strong> disponibles 
                                                <span class="text-muted">|</span> 
                                                <span class="@(prestados > 0 ? "text-orange" : "")">@prestados prestados</span>
                                                <span class="text-muted">|</span> 
                                                <span class="@(perdidos > 0 ? "text-danger" : "")">@perdidos perdidos</span>
                                                <span class="text-muted">|</span> 
                                                @totalEjemplares total
                                            </td>
                                            <td>
                                                <AuthorizeView Policy="@RoleConstants.Permissions.Libros.Read">
                                                    <Authorized>
                                                        <button class="btn btn-primary btn-sm" @onclick="() => VerDetalleLibro(libro.LibroId)">
                                                            <i class="bi bi-eye"></i> Detalles
                                                        </button>
                                                    </Authorized>
                                                </AuthorizeView>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger mt-3">
            @_errorMessage
        </div>
    }
</div>

@if (_mostrarConfirmacion)
{
    <div class="modal fade show" style="display: block;" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirmar eliminación</h5>
                    <button type="button" class="btn-close" @onclick="CancelarEliminacion"></button>
                </div>
                <div class="modal-body">
                    ¿Está seguro que desea eliminar el autor '@_autor?.Nombre'?
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CancelarEliminacion">Cancelar</button>
                    <button type="button" class="btn btn-danger" @onclick="EliminarAutor">Confirmar</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@code {
    [Parameter]
    public int AutorId { get; set; }

    private AutorDTO? _autor;
    private IEnumerable<LibroDTO> _libros = Array.Empty<LibroDTO>();
    private string _errorMessage = string.Empty;
    private bool _mostrarConfirmacion;
    private Dictionary<string, int> ejemplaresPorIsbn = new();
    private Dictionary<string, int> ejemplaresPrestadosPorIsbn = new();
    private Dictionary<string, int> ejemplaresPerdidosPorIsbn = new();

    protected override async Task OnInitializedAsync()
    {
        _autor = await AutorService.GetByIdAsync(AutorId);
        if (_autor == null)
        {
            NavigationManager.NavigateTo("/autores");
            return;
        }

        // Get books by author if there are any
        if (_autor.CantidadLibros > 0)
        {
            var libros = await LibroService.GetLibrosByAutorIdAsync(AutorId);
            _libros = libros ?? Array.Empty<LibroDTO>();
            await CargarNumeroEjemplares();
        }
    }

    private async Task CargarNumeroEjemplares()
    {
        if (_libros == null) return;
        
        var isbnsUnicos = _libros.Select(l => l.ISBN).Distinct();
        
        foreach (var isbn in isbnsUnicos)
        {
            var count = await LibroService.ContarEjemplaresPorIsbnAsync(isbn);
            ejemplaresPorIsbn[isbn] = count;
            
            var prestados = await LibroService.ContarEjemplaresPrestadosPorIsbnAsync(isbn);
            ejemplaresPrestadosPorIsbn[isbn] = prestados;

            var perdidos = await LibroService.ContarEjemplaresPerdidosPorIsbnAsync(isbn);
            ejemplaresPerdidosPorIsbn[isbn] = perdidos;
        }
    }

    private void Volver()
    {
        NavigationManager.NavigateTo("/autores");
    }

    private void EditarAutor()
    {
        NavigationManager.NavigateTo($"/autores/editar/{AutorId}");
    }

    private void VerDetalleLibro(int libroId)
    {
        NavigationManager.NavigateTo($"/libros/{libroId}");
    }

    private void MostrarConfirmacion()
    {
        _mostrarConfirmacion = true;
    }

    private void CancelarEliminacion()
    {
        _mostrarConfirmacion = false;
    }

    private async Task EliminarAutor()
    {
        _mostrarConfirmacion = false;
        
        try
        {
            var result = await AutorService.DeleteAsync(AutorId);
            if (result)
            {
                NavigationManager.NavigateTo("/autores");
            }
            else
            {
                _errorMessage = "No se pudo eliminar el autor. Puede que tenga libros asociados o ya no exista.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error al eliminar el autor: {ex.Message}";
        }
    }
}