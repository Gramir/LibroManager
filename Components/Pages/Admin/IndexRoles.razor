@page "/admin/roles"
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using System.ComponentModel.DataAnnotations
@using LibroManager.Models
@using LibroManager.Data.Context
@using LibroManager.Constants
@inject UserManager<ApplicationUser> UserManager
@inject RoleManager<IdentityRole> RoleManager
@inject NavigationManager NavigationManager
@attribute [Authorize(Roles = RoleConstants.AdminRole)]
@rendermode InteractiveServer

<PageTitle>Gestión de Roles - LibroManager</PageTitle>

<div class="container">
    <h1>Gestión de Roles</h1>

    <div class="mb-3">
        <button class="btn btn-primary" @onclick="MostrarModalCrearRole">
            <i class="bi bi-plus-circle"></i> Crear Rol
        </button>
    </div>

    @if (_roles == null)
    {
        <div class="d-flex justify-content-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Permisos</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var role in _roles)
                    {
                        <tr>
                            <td>@GetRoleDisplayName(role.Name)</td>
                            <td>
                                <small>
                                    @string.Join(", ", _rolesPermisos.GetValueOrDefault(role.Id, new List<string>())
                                        .Select(GetPermisoDisplayName))
                                </small>
                            </td>
                            <td>
                                @if (role.Name != RoleConstants.AdminRole)
                                {
                                    <button class="btn btn-warning btn-sm me-1" @onclick="() => EditarRole(role)">
                                        <i class="bi bi-pencil"></i> Editar
                                    </button>
                                    <button class="btn btn-danger btn-sm" @onclick="() => MostrarConfirmacion(role)">
                                        <i class="bi bi-trash"></i> Eliminar
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @if (_mostrarModalCrear)
    {
        <div class="modal fade show" style="display: block;" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Crear Rol</h5>
                        <button type="button" class="btn-close" @onclick="CerrarModal"></button>
                    </div>
                    <EditForm Model="_nuevoRole" OnValidSubmit="CrearRole">
                        <DataAnnotationsValidator />
                        <div class="modal-body">
                            <div class="mb-3">
                                <label class="form-label">Nombre del Rol</label>
                                <InputText @bind-Value="_nuevoRole.Name" class="form-control" />
                                <ValidationMessage For="@(() => _nuevoRole.Name)" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Permisos</label>
                                <div class="row">
                                    @foreach (var modulo in _permisosAgrupados)
                                    {
                                        <div class="col-md-6 mb-3">
                                            <h6>@modulo.Key</h6>
                                            @foreach (var permiso in modulo.Value)
                                            {
                                                <div class="form-check">
                                                    <InputCheckbox class="form-check-input" 
                                                                @bind-Value="_permisosSeleccionados[permiso]" />
                                                    <label class="form-check-label">
                                                        @GetPermisoAccionDisplayName(permiso.Split('.').Last())
                                                    </label>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" @onclick="CerrarModal">Cancelar</button>
                            <button type="submit" class="btn btn-primary">Guardar</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
        <div class="modal-backdrop fade show"></div>
    }

    @if (_mostrarModalEditar && _roleEditar != null)
    {
        <div class="modal fade show" style="display: block;" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Editar Rol</h5>
                        <button type="button" class="btn-close" @onclick="CerrarModal"></button>
                    </div>
                    <EditForm Model="_roleEditar" OnValidSubmit="GuardarEdicionRole">
                        <DataAnnotationsValidator />
                        <div class="modal-body">
                            <div class="mb-3">
                                <label class="form-label">Nombre del Rol</label>
                                <InputText @bind-Value="_roleEditar.Name" class="form-control" />
                                <ValidationMessage For="@(() => _roleEditar.Name)" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Permisos</label>
                                <div class="row">
                                    @foreach (var modulo in _permisosAgrupados)
                                    {
                                        <div class="col-md-6 mb-3">
                                            <h6>@modulo.Key</h6>
                                            @foreach (var permiso in modulo.Value)
                                            {
                                                <div class="form-check">
                                                    <InputCheckbox class="form-check-input" 
                                                                @bind-Value="_permisosSeleccionados[permiso]" />
                                                    <label class="form-check-label">
                                                        @GetPermisoAccionDisplayName(permiso.Split('.').Last())
                                                    </label>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" @onclick="CerrarModal">Cancelar</button>
                            <button type="submit" class="btn btn-primary">Guardar</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
        <div class="modal-backdrop fade show"></div>
    }

    @if (_mostrarConfirmacion && _roleAEliminar != null)
    {
        <div class="modal fade show" style="display: block;" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Confirmar eliminación</h5>
                        <button type="button" class="btn-close" @onclick="CancelarEliminacion"></button>
                    </div>
                    <div class="modal-body">
                        <p>¿Está seguro que desea eliminar el rol '@GetRoleDisplayName(_roleAEliminar.Name)'?</p>
                        @if (_tieneUsuariosAsignados)
                        {
                            <div class="alert alert-danger">
                                <i class="bi bi-exclamation-triangle-fill"></i>
                                No se puede eliminar este rol porque tiene usuarios asignados.
                            </div>
                        }
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CancelarEliminacion">Cancelar</button>
                        <button type="button" class="btn btn-danger" @onclick="EliminarRole" disabled="@_tieneUsuariosAsignados">
                            Confirmar
                        </button>
                    </div>
                </div>
            </div>
        </div>
        <div class="modal-backdrop fade show"></div>
    }

    @if (!string.IsNullOrEmpty(_mensajeError))
    {
        <div class="alert alert-danger mt-3">
            @_mensajeError
        </div>
    }
</div>

@code {
    private List<IdentityRole>? _roles;
    private Dictionary<string, List<string>> _rolesPermisos = new();
    private Dictionary<string, List<string>> _permisosAgrupados = new();
    private Dictionary<string, bool> _permisosSeleccionados = new();
    private bool _mostrarModalCrear;
    private bool _mostrarModalEditar;
    private string? _mensajeError;
    private bool _mostrarConfirmacion;
    private IdentityRole? _roleAEliminar;
    private bool _tieneUsuariosAsignados;

    private class RoleModel
    {
        [Required(ErrorMessage = "El nombre del rol es requerido")]
        public string Name { get; set; } = "";
    }

    private RoleModel _nuevoRole = new();
    private RoleModel _roleEditar = new();
    private IdentityRole? _roleActual;

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
        InitPermisosAgrupados();
    }

    private void InitPermisosAgrupados()
    {
        // Agrupar permisos por módulo
        var allPermissions = typeof(RoleConstants.Permissions).GetNestedTypes()
            .SelectMany(t => t.GetFields())
            .Where(f => f.IsPublic && f.IsStatic && f.IsLiteral)
            .Select(f => f.GetValue(null)?.ToString() ?? "")
            .Where(p => !string.IsNullOrEmpty(p))
            .ToList();

        _permisosAgrupados = allPermissions
            .GroupBy(p => p.Split('.')[0])
            .ToDictionary(g => g.Key, g => g.ToList());
    }

    private async Task CargarDatos()
    {
        try
        {
            _roles = await RoleManager.Roles.OrderBy(r => r.Name).ToListAsync();
            _rolesPermisos.Clear();

            foreach (var role in _roles)
            {
                var claims = await RoleManager.GetClaimsAsync(role);
                _rolesPermisos[role.Id] = claims.Where(c => c.Type == "Permission")
                    .Select(c => c.Value)
                    .ToList();
            }
        }
        catch (Exception ex)
        {
            _mensajeError = $"Error al cargar los datos: {ex.Message}";
        }
    }

    private void MostrarModalCrearRole()
    {
        _nuevoRole = new RoleModel();
        InitPermisosSeleccionados(new List<string>());
        _mostrarModalCrear = true;
    }

    private void InitPermisosSeleccionados(List<string> permisosActuales)
    {
        _permisosSeleccionados = _permisosAgrupados
            .SelectMany(g => g.Value)
            .ToDictionary(p => p, p => permisosActuales.Contains(p));
    }

    private async Task CrearRole()
    {
        try
        {
            var roleResult = await RoleManager.CreateAsync(new IdentityRole(_nuevoRole.Name));
            if (roleResult.Succeeded)
            {
                var role = await RoleManager.FindByNameAsync(_nuevoRole.Name);
                if (role != null)
                {
                    var permisosSeleccionados = _permisosSeleccionados
                        .Where(p => p.Value)
                        .Select(p => p.Key)
                        .ToList();

                    foreach (var permiso in permisosSeleccionados)
                    {
                        await RoleManager.AddClaimAsync(role, new System.Security.Claims.Claim("Permission", permiso));
                    }
                }

                await CargarDatos();
                CerrarModal();
            }
            else
            {
                _mensajeError = string.Join(", ", roleResult.Errors.Select(e => e.Description));
            }
        }
        catch (Exception ex)
        {
            _mensajeError = $"Error al crear el rol: {ex.Message}";
        }
    }

    private async Task EditarRole(IdentityRole role)
    {
        _roleActual = role;
        _roleEditar = new RoleModel { Name = role.Name ?? "" };
        var claims = await RoleManager.GetClaimsAsync(role);
        var permisos = claims.Where(c => c.Type == "Permission")
            .Select(c => c.Value)
            .ToList();
        InitPermisosSeleccionados(permisos);
        _mostrarModalEditar = true;
    }

    private async Task GuardarEdicionRole()
    {
        try
        {
            if (_roleActual == null) return;

            if (_roleActual.Name != _roleEditar.Name)
            {
                var roleUpdateResult = await RoleManager.SetRoleNameAsync(_roleActual, _roleEditar.Name);
                if (!roleUpdateResult.Succeeded)
                {
                    _mensajeError = string.Join(", ", roleUpdateResult.Errors.Select(e => e.Description));
                    return;
                }
            }

            // Actualizar permisos
            var claims = await RoleManager.GetClaimsAsync(_roleActual);
            foreach (var claim in claims)
            {
                await RoleManager.RemoveClaimAsync(_roleActual, claim);
            }

            var permisosSeleccionados = _permisosSeleccionados
                .Where(p => p.Value)
                .Select(p => p.Key)
                .ToList();

            foreach (var permiso in permisosSeleccionados)
            {
                await RoleManager.AddClaimAsync(_roleActual, new System.Security.Claims.Claim("Permission", permiso));
            }

            await CargarDatos();
            CerrarModal();
        }
        catch (Exception ex)
        {
            _mensajeError = $"Error al actualizar el rol: {ex.Message}";
        }
    }

    private async Task MostrarConfirmacion(IdentityRole role)
    {
        _roleAEliminar = role;
        _tieneUsuariosAsignados = (await UserManager.GetUsersInRoleAsync(role.Name!)).Any();
        _mostrarConfirmacion = true;
    }

    private void CancelarEliminacion()
    {
        _mostrarConfirmacion = false;
        _roleAEliminar = null;
        _tieneUsuariosAsignados = false;
    }

    private async Task EliminarRole()
    {
        try
        {
            if (_roleAEliminar == null) return;

            // Verificar nuevamente si tiene usuarios asignados
            if ((await UserManager.GetUsersInRoleAsync(_roleAEliminar.Name!)).Any())
            {
                _mensajeError = "No se puede eliminar el rol porque tiene usuarios asignados.";
                return;
            }

            var result = await RoleManager.DeleteAsync(_roleAEliminar);
            if (result.Succeeded)
            {
                await CargarDatos();
            }
            else
            {
                _mensajeError = string.Join(", ", result.Errors.Select(e => e.Description));
            }
        }
        catch (Exception ex)
        {
            _mensajeError = $"Error al eliminar el rol: {ex.Message}";
        }
        finally
        {
            CancelarEliminacion();
        }
    }

    private void CerrarModal()
    {
        _mostrarModalCrear = false;
        _mostrarModalEditar = false;
        _mensajeError = null;
        _roleActual = null;
    }

    private string GetRoleDisplayName(string? roleName) => roleName switch
    {
        RoleConstants.AdminRole => "Administrador",
        RoleConstants.LibrarianRole => "Bibliotecario",
        _ => roleName ?? string.Empty
    };

    private string GetPermisoDisplayName(string permiso)
    {
        var partes = permiso.Split('.');
        if (partes.Length != 2) return permiso;

        var modulo = partes[0] switch
        {
            "Libros" => "Libros",
            "Estudiantes" => "Estudiantes",
            "Prestamos" => "Préstamos",
            "Autores" => "Autores",
            "Categorias" => "Categorías",
            "Ubicaciones" => "Ubicaciones",
            "Users" => "Usuarios",
            _ => partes[0]
        };

        var accion = partes[1] switch
        {
            "Create" => "Crear",
            "Read" => "Ver",
            "Update" => "Editar",
            "Delete" => "Eliminar",
            "List" => "Listar",
            "Approve" => "Aprobar",
            "Reject" => "Rechazar",
            "Return" => "Devolver",
            "Export" => "Exportar",
            "Import" => "Importar",
            "ManageRoles" => "Gestionar Roles",
            "ManageUsers" => "Gestionar Usuarios",
            _ => partes[1]
        };

        return $"{modulo}: {accion}";
    }

    private string GetPermisoAccionDisplayName(string accion) => accion switch
    {
        "Create" => "Crear",
        "Read" => "Ver",
        "Update" => "Editar",
        "Delete" => "Eliminar",
        "List" => "Listar",
        "Approve" => "Aprobar",
        "Reject" => "Rechazar",
        "Return" => "Devolver",
        "Export" => "Exportar",
        "Import" => "Importar",
        "ManageRoles" => "Gestionar Roles",
        "ManageUsers" => "Gestionar Usuarios",
        _ => accion
    };

    private async Task<bool> IsUserLibrarian(ApplicationUser user)
    {
        return await UserManager.IsInRoleAsync(user, RoleConstants.LibrarianRole);
    }
}