@page "/admin/usuarios"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using LibroManager.Models
@using LibroManager.Constants
@using LibroManager.Services.Interfaces
@using System.ComponentModel.DataAnnotations
@inject IUserService UserService
@inject NavigationManager NavigationManager
@attribute [Authorize(Policy = RoleConstants.Permissions.Users.ManageUsers)]
@rendermode InteractiveServer
<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<PageTitle>Gestión de Usuarios - LibroManager</PageTitle>

<div class="container">
    <h1>Gestión de Usuarios</h1>

    <div class="mb-3">
        <button class="btn btn-primary" @onclick="MostrarModalCrearUsuario">
            <i class="bi bi-person-plus"></i> Crear Usuario
        </button>
    </div>

    @if (_usuarios == null)
    {
        <div class="d-flex justify-content-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Email</th>
                        <th>Nombre</th>
                        <th>Rol</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var usuario in _usuarios)
                    {
                        var roles = _usuariosRoles.GetValueOrDefault(usuario.Id, new List<string>());
                        var isAdmin = roles.Contains(RoleConstants.AdminRole);
                        <tr>
                            <td>@usuario.Email</td>
                            <td>@usuario.NombreCompleto</td>
                            <td>
                                @(isAdmin ? "Administrador" : "Bibliotecario")
                            </td>
                            <td>
                                <button class="btn btn-warning btn-sm me-1" @onclick="() => EditarUsuario(usuario)">
                                    <i class="bi bi-pencil"></i> Editar
                                </button>
                                @if (!isAdmin)
                                {
                                    <button class="btn btn-danger btn-sm" @onclick="() => EliminarUsuario(usuario)">
                                        <i class="bi bi-trash"></i> Eliminar
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @if (_mostrarModalCrear)
    {
        <div class="modal fade show" style="display: block;" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Crear Usuario</h5>
                        <button type="button" class="btn-close" @onclick="CerrarModal"></button>
                    </div>
                    <EditForm Model="@_nuevoUsuario" OnValidSubmit="CrearUsuario">
                        <DataAnnotationsValidator />
                        <div class="modal-body">
                            <div class="mb-3">
                                <label class="form-label">Email</label>
                                <InputText @bind-Value="_nuevoUsuario.Email" class="form-control" />
                                <ValidationMessage For="@(() => _nuevoUsuario.Email)" />
                                @if (_emailExistente)
                                {
                                    <div class="text-danger">Este correo electrónico ya está en uso</div>
                                }
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Nombre Completo</label>
                                <InputText @bind-Value="_nuevoUsuario.NombreCompleto" class="form-control" />
                                <ValidationMessage For="@(() => _nuevoUsuario.NombreCompleto)" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Contraseña</label>
                                <InputText type="password" @bind-Value="_nuevoUsuario.Password" class="form-control" />
                                <ValidationMessage For="@(() => _nuevoUsuario.Password)" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Confirmar Contraseña</label>
                                <InputText type="password" @bind-Value="_nuevoUsuario.ConfirmPassword" class="form-control" />
                                <ValidationMessage For="@(() => _nuevoUsuario.ConfirmPassword)" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Rol</label>
                                <div class="form-check">
                                    <InputRadioGroup @bind-Value="_nuevoUsuario.Role" class="btn-group" Name="roles">
                                        <div class="mb-2">
                                            <InputRadio Value="@RoleConstants.AdminRole" class="btn-check" id="admin-role" />
                                            <label class="btn btn-outline-primary" for="admin-role">Administrador</label>
                                        </div>
                                        <div>
                                            <InputRadio Value="@RoleConstants.LibrarianRole" class="btn-check" id="librarian-role" />
                                            <label class="btn btn-outline-primary" for="librarian-role">Bibliotecario</label>
                                        </div>
                                    </InputRadioGroup>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" @onclick="CerrarModal">Cancelar</button>
                            <button type="submit" class="btn btn-primary">Guardar</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
        <div class="modal-backdrop fade show"></div>
    }

    @if (_mostrarModalEditar && _usuarioEditar != null)
    {
        <div class="modal fade show" style="display: block;" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Editar Usuario</h5>
                        <button type="button" class="btn-close" @onclick="CerrarModal"></button>
                    </div>
                    <EditForm Model="@_usuarioEditar" OnValidSubmit="GuardarEdicionUsuario">
                        <DataAnnotationsValidator />
                        <div class="modal-body">
                            <div class="mb-3">
                                <label class="form-label">Email</label>
                                <InputText @bind-Value="@_usuarioEditar.Email" class="form-control" disabled />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Nombre Completo</label>
                                <InputText @bind-Value="@_usuarioEditar.NombreCompleto" class="form-control" />
                                <ValidationMessage For="@(() => _usuarioEditar.NombreCompleto)" />
                            </div>
                            @{
                                var roles = _usuariosRoles.GetValueOrDefault(_usuarioEditar.Id, new List<string>());
                                var isAdmin = roles.Contains(RoleConstants.AdminRole);
                            }
                            @if (!isAdmin)
                            {
                                <div class="mb-3">
                                    <label class="form-label">Rol</label>
                                    <div class="form-check">
                                        <InputRadioGroup @bind-Value="_rolEditar" class="btn-group" Name="roles">
                                            <div class="mb-2">
                                                <InputRadio Value="@RoleConstants.AdminRole" class="btn-check" id="edit-admin-role" />
                                                <label class="btn btn-outline-primary" for="edit-admin-role">Administrador</label>
                                            </div>
                                            <div>
                                                <InputRadio Value="@RoleConstants.LibrarianRole" class="btn-check" id="edit-librarian-role" />
                                                <label class="btn btn-outline-primary" for="edit-librarian-role">Bibliotecario</label>
                                            </div>
                                        </InputRadioGroup>
                                    </div>
                                </div>
                            }
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" @onclick="CerrarModal">Cancelar</button>
                            <button type="submit" class="btn btn-primary">Guardar</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
        <div class="modal-backdrop fade show"></div>
    }

    @if (_mostrarModalConfirmacion)
    {
        <div class="modal fade show" style="display: block;" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Confirmar Eliminación</h5>
                        <button type="button" class="btn-close" @onclick="CerrarModal"></button>
                    </div>
                    <div class="modal-body">
                        <p>¿Está seguro que desea eliminar al usuario @_usuarioAEliminar?.Email?</p>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CerrarModal">Cancelar</button>
                        <button type="button" class="btn btn-danger" @onclick="ConfirmarEliminarUsuario">Eliminar</button>
                    </div>
                </div>
            </div>
        </div>
        <div class="modal-backdrop fade show"></div>
    }

    @if (!string.IsNullOrEmpty(_mensajeError))
    {
        <div class="alert alert-danger mt-3">
            @_mensajeError
        </div>
    }
</div>

@code {
    private List<ApplicationUser>? _usuarios;
    private Dictionary<string, List<string>> _usuariosRoles = new();
    private bool _mostrarModalCrear;
    private bool _mostrarModalEditar;
    private bool _mostrarModalConfirmacion;
    private string? _mensajeError;
    private bool _emailExistente;
    private NuevoUsuarioModel _nuevoUsuario = new();
    private ApplicationUser? _usuarioEditar;
    private ApplicationUser? _usuarioAEliminar;
    private string _rolEditar = RoleConstants.LibrarianRole;

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        try
        {
            _usuarios = (await UserService.GetAllUsersAsync()).ToList();
            _usuariosRoles = await UserService.GetAllUsersWithRolesAsync();
        }
        catch (Exception ex)
        {
            _mensajeError = $"Error al cargar los datos: {ex.Message}";
        }
    }

    private void MostrarModalCrearUsuario()
    {
        _nuevoUsuario = new NuevoUsuarioModel { Role = RoleConstants.LibrarianRole };
        _mostrarModalCrear = true;
        _emailExistente = false;
    }

    private async Task CrearUsuario()
    {
        try
        {
            // Verificar si ya existe un usuario con el mismo email
            var existeUsuario = await UserService.GetUserByEmailAsync(_nuevoUsuario.Email);
            if (existeUsuario != null)
            {
                _emailExistente = true;
                return;
            }

            var usuario = new ApplicationUser
            {
                UserName = _nuevoUsuario.Email,
                Email = _nuevoUsuario.Email,
                NombreCompleto = _nuevoUsuario.NombreCompleto,
                EmailConfirmed = true,
                FechaCreacion = DateTime.UtcNow
            };

            var roles = new List<string> { _nuevoUsuario.Role };
            var (result, user) = await UserService.CreateUserAsync(usuario, _nuevoUsuario.Password, roles);

            if (result.Succeeded)
            {
                await CargarDatos();
                CerrarModal();
            }
            else
            {
                _mensajeError = string.Join(", ", result.Errors.Select(e => e.Description));
            }
        }
        catch (Exception ex)
        {
            _mensajeError = $"Error al crear el usuario: {ex.Message}";
        }
    }

    private void EditarUsuario(ApplicationUser usuario)
    {
        _usuarioEditar = usuario;
        var roles = _usuariosRoles.GetValueOrDefault(usuario.Id, new List<string>());
        _rolEditar = roles.Contains(RoleConstants.AdminRole) ? RoleConstants.AdminRole : RoleConstants.LibrarianRole;
        _mostrarModalEditar = true;
    }

    private async Task GuardarEdicionUsuario()
    {
        try
        {
            if (_usuarioEditar == null) return;

            var roles = new List<string> { _rolEditar };
            var result = await UserService.UpdateUserAsync(_usuarioEditar, roles);

            if (result.Succeeded)
            {
                await CargarDatos();
                CerrarModal();
            }
            else
            {
                _mensajeError = String.Join(", ", result.Errors.Select(e => e.Description));
            }
        }
        catch (Exception ex)
        {
            _mensajeError = $"Error al actualizar el usuario: {ex.Message}";
        }
    }

    private void EliminarUsuario(ApplicationUser usuario)
    {
        _usuarioAEliminar = usuario;
        _mostrarModalConfirmacion = true;
    }

    private async Task ConfirmarEliminarUsuario()
    {
        if (_usuarioAEliminar == null) return;

        try
        {
            var result = await UserService.DeleteUserAsync(_usuarioAEliminar.Id);
            if (result.Succeeded)
            {
                await CargarDatos();
            }
            else
            {
                _mensajeError = string.Join(", ", result.Errors.Select(e => e.Description));
            }
        }
        catch (Exception ex)
        {
            _mensajeError = $"Error al eliminar el usuario: {ex.Message}";
        }
        finally
        {
            CerrarModal();
        }
    }

    private void CerrarModal()
    {
        _mostrarModalCrear = false;
        _mostrarModalEditar = false;
        _mostrarModalConfirmacion = false;
        _mensajeError = null;
        _emailExistente = false;
        _usuarioAEliminar = null;
    }

    private class NuevoUsuarioModel
    {
        [Required(ErrorMessage = "El email es requerido")]
        [EmailAddress(ErrorMessage = "El email no tiene un formato válido")]
        public string Email { get; set; } = "";

        [Required(ErrorMessage = "El nombre es requerido")]
        public string NombreCompleto { get; set; } = "";

        [Required(ErrorMessage = "La contraseña es requerida")]
        [StringLength(100, ErrorMessage = "La contraseña debe tener al menos {2} caracteres.", MinimumLength = 6)]
        public string Password { get; set; } = "";

        [Compare("Password", ErrorMessage = "Las contraseñas no coinciden")]
        public string ConfirmPassword { get; set; } = "";

        [Required(ErrorMessage = "El rol es requerido")]
        public string Role { get; set; } = RoleConstants.LibrarianRole;
    }
}