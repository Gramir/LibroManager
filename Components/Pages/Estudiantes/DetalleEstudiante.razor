@page "/estudiantes/{EstudianteId:int}"
@using Microsoft.AspNetCore.Authorization
@using LibroManager.DTOs
@using LibroManager.Models
@using LibroManager.Services.Interfaces
@using LibroManager.Constants
@inject IEstudianteService EstudianteService
@inject IPrestamoService PrestamoService
@inject NavigationManager NavigationManager
@attribute [Authorize(Policy = RoleConstants.Permissions.Estudiantes.Read)]
@rendermode InteractiveServer
<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<PageTitle>Detalle del Estudiante</PageTitle>

<div class="container mt-4">
    @if (_estudiante == null)
    {
        <div class="d-flex justify-content-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h3 class="mb-0">@_estudiante.Nombre</h3>
                <div>
                    <AuthorizeView Policy="@RoleConstants.Permissions.Estudiantes.Update">
                        <Authorized>
                            <button class="btn btn-warning me-2" @onclick="EditarEstudiante">Editar</button>
                        </Authorized>
                    </AuthorizeView>
                    <AuthorizeView Policy="@RoleConstants.Permissions.Estudiantes.Delete">
                        <Authorized>
                            <button class="btn btn-danger me-2" @onclick="MostrarConfirmacion" disabled="@(_estudiante.PrestamosActivos > 0)">
                                Eliminar
                            </button>
                        </Authorized>
                    </AuthorizeView>
                    <button class="btn btn-secondary" @onclick="Volver">Volver</button>
                    <AuthorizeView Policy="@RoleConstants.Permissions.Estudiantes.Delete">
                        <Authorized>
                            @if (_estudiante.PrestamosActivos > 0)
                            {
                                <div class="text-danger mt-2 small">
                                    <i class="bi bi-exclamation-circle"></i> No se puede eliminar un estudiante que tiene préstamos activos
                                </div>
                            }
                        </Authorized>
                    </AuthorizeView>
                </div>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <dl class="row">
                            <dt class="col-sm-4">Email:</dt>
                            <dd class="col-sm-8">@_estudiante.Email</dd>
                            <dt class="col-sm-4">Fecha de inscripción:</dt>
                            <dd class="col-sm-8">@_estudiante.FechaInscripcion.ToShortDateString()</dd>
                            <dt class="col-sm-4">Préstamos Activos:</dt>
                            <dd class="col-sm-8">@_estudiante.PrestamosActivos</dd>
                        </dl>
                    </div>
                </div>

                @if (_prestamos.Any())
                {
                    <div class="mt-4">
                        <h4>Préstamos del Estudiante</h4>
                        <div class="table-responsive">
                            <table class="table">
                                <thead>
                                    <tr>
                                        <th>Libro</th>
                                        <th>Serial</th>
                                        <th>Fecha de préstamo</th>
                                        <th>Fecha de vencimiento</th>
                                        <th>Fecha de devolución</th>
                                        <th>Estado</th>
                                        <th>Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var prestamo in _prestamos)
                                    {
                                        <tr>
                                            <td>@prestamo.LibroTitulo</td>
                                            <td>@prestamo.LibroSerial</td>
                                            <td>@prestamo.FechaPrestamo.ToShortDateString()</td>
                                            <td>@prestamo.FechaVencimiento.ToShortDateString()</td>
                                            <td>
                                                @(prestamo.FechaDevolucion.HasValue ? prestamo.FechaDevolucion.Value.ToShortDateString() : "-")
                                            </td>
                                            <td>
                                                <span class="badge @GetEstadoBadgeClass(prestamo)">
                                                    @GetEstadoText(prestamo)
                                                </span>
                                            </td>
                                            <td>
                                                <AuthorizeView Policy="@RoleConstants.Permissions.Prestamos.Read">
                                                    <Authorized>
                                                        <button class="btn btn-primary btn-sm me-2" @onclick="() => VerDetalleLibro(prestamo.PrestamoId)">
                                                            <i class="bi bi-eye"></i> Detalles
                                                        </button>
                                                    </Authorized>
                                                </AuthorizeView>
                                                <AuthorizeView Policy="@RoleConstants.Permissions.Prestamos.Update">
                                                    <Authorized>
                                                        @if (prestamo.EstaActivo)
                                                        {
                                                            <button class="btn btn-success btn-sm" @onclick="() => DevolverPrestamo(prestamo)">
                                                                <i class="bi bi-check-circle"></i> Devolver
                                                            </button>
                                                        }
                                                    </Authorized>
                                                </AuthorizeView>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger mt-3">
            @_errorMessage
        </div>
    }
</div>

@if (_mostrarConfirmacion)
{
    <div class="modal fade show" style="display: block;" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirmar eliminación</h5>
                    <button type="button" class="btn-close" @onclick="CancelarEliminacion"></button>
                </div>
                <div class="modal-body">
                    ¿Está seguro que desea eliminar el estudiante '@_estudiante?.Nombre'?
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CancelarEliminacion">Cancelar</button>
                    <button type="button" class="btn btn-danger" @onclick="EliminarEstudiante">Confirmar</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@if (_mostrarConfirmacionDevolucion)
{
    <div class="modal fade show" style="display: block;" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirmar devolución</h5>
                    <button type="button" class="btn-close" @onclick="CancelarDevolucion"></button>
                </div>
                <div class="modal-body">
                    <p>¿Está seguro que desea devolver el siguiente libro?</p>
                    <dl class="row">
                        <dt class="col-sm-3">Título:</dt>
                        <dd class="col-sm-9">@_prestamoADevolver?.LibroTitulo</dd>
                        <dt class="col-sm-3">Serial:</dt>
                        <dd class="col-sm-9">@_prestamoADevolver?.LibroSerial</dd>
                    </dl>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CancelarDevolucion">Cancelar</button>
                    <button type="button" class="btn btn-success" @onclick="ConfirmarDevolucion">Confirmar</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@code {
    [Parameter]
    public int EstudianteId { get; set; }

    private EstudianteDTO? _estudiante;
    private IEnumerable<PrestamoDTO> _prestamos = Array.Empty<PrestamoDTO>();
    private string _errorMessage = string.Empty;
    private bool _mostrarConfirmacion;
    private bool _mostrarConfirmacionDevolucion;
    private PrestamoDTO? _prestamoADevolver;

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        _estudiante = await EstudianteService.GetByIdAsync(EstudianteId);
        if (_estudiante == null)
        {
            NavigationManager.NavigateTo("/estudiantes");
            return;
        }

        var prestamos = await PrestamoService.GetPrestamosByEstudianteAsync(EstudianteId);
        _prestamos = prestamos ?? Array.Empty<PrestamoDTO>();
    }

    private string GetEstadoText(PrestamoDTO prestamo)
    {
        if (prestamo.FechaDevolucion.HasValue)
            return "Concluido";
        if (prestamo.FechaVencimiento < DateTime.Now)
            return "Expirado";
        return "Activo";
    }

    private string GetEstadoBadgeClass(PrestamoDTO prestamo)
    {
        if (prestamo.FechaDevolucion.HasValue)
            return "bg-success";
        if (prestamo.FechaVencimiento < DateTime.Now)
            return "bg-danger";
        return "bg-warning";
    }

    private void Volver()
    {
        NavigationManager.NavigateTo("/estudiantes");
    }

    private void EditarEstudiante()
    {
        NavigationManager.NavigateTo($"/estudiantes/editar/{EstudianteId}");
    }

    private void VerDetalleLibro(int prestamoId)
    {
        NavigationManager.NavigateTo($"/prestamos/{prestamoId}");
    }

    private void DevolverPrestamo(PrestamoDTO prestamo)
    {
        _prestamoADevolver = prestamo;
        _mostrarConfirmacionDevolucion = true;
    }

    private void CancelarDevolucion()
    {
        _mostrarConfirmacionDevolucion = false;
        _prestamoADevolver = null;
    }

    private async Task ConfirmarDevolucion()
    {
        if (_prestamoADevolver == null) return;

        try
        {
            var prestamoUpdateDto = new PrestamoUpdateDTO
            {
                PrestamoId = _prestamoADevolver.PrestamoId,
                LibroId = _prestamoADevolver.LibroId,
                EstudianteId = _prestamoADevolver.EstudianteId,
                FechaPrestamo = _prestamoADevolver.FechaPrestamo,
                FechaVencimiento = _prestamoADevolver.FechaVencimiento,
                FechaDevolucion = DateTime.Now,
                Estado = EstadoPrestamo.Concluido
            };

            var result = await PrestamoService.UpdateAsync(prestamoUpdateDto);
            if (result)
            {
                await CargarDatos();
            }
            else
            {
                _errorMessage = "No se pudo devolver el préstamo. Por favor, intente nuevamente.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error al devolver el préstamo: {ex.Message}";
        }
        finally
        {
            _mostrarConfirmacionDevolucion = false;
            _prestamoADevolver = null;
        }
    }

    private void MostrarConfirmacion()
    {
        _mostrarConfirmacion = true;
    }

    private void CancelarEliminacion()
    {
        _mostrarConfirmacion = false;
    }

    private async Task EliminarEstudiante()
    {
        _mostrarConfirmacion = false;
        
        try
        {
            var result = await EstudianteService.DeleteAsync(EstudianteId);
            if (result)
            {
                NavigationManager.NavigateTo("/estudiantes");
            }
            else
            {
                _errorMessage = "No se pudo eliminar el estudiante. Puede que tenga préstamos activos o ya no exista.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error al eliminar el estudiante: {ex.Message}";
        }
    }
}

<style>
    .estado-vencido {
        color: red;
        font-weight: bold;
    }
</style>