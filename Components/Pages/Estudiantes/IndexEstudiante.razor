@page "/estudiantes"
@using Microsoft.AspNetCore.Authorization
@using LibroManager.Services.Interfaces
@using LibroManager.DTOs
@using LibroManager.Constants
@inject IEstudianteService EstudianteService
@inject NavigationManager NavigationManager
@attribute [Authorize(Policy = RoleConstants.Permissions.Estudiantes.Read)]
@rendermode InteractiveServer
<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<PageTitle>Estudiantes - LibroManager</PageTitle>

<h1>Catálogo de Estudiantes</h1>

<AuthorizeView Policy="@RoleConstants.Permissions.Estudiantes.Create">
    <Authorized>
        <div class="mb-3">
            <button class="btn btn-primary" @onclick="CrearEstudiante">
                <i class="bi bi-plus-circle"></i> Crear Estudiante
            </button>
        </div>
    </Authorized>
</AuthorizeView>

@if (estudiantes == null)
{
    <p><em>Cargando...</em></p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Nombre</th>
                    <th>Email</th>
                    <th>Fecha de Inscripción</th>
                    <th>Préstamos Activos</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var estudiante in estudiantes)
                {
                    <tr>
                        <td>@estudiante.EstudianteId</td>
                        <td>@estudiante.Nombre</td>
                        <td>@estudiante.Email</td>
                        <td>@estudiante.FechaInscripcion.ToShortDateString()</td>
                        <td>
                            <span class="badge @(estudiante.PrestamosActivos > 0 ? "bg-warning" : "bg-success")">
                                @estudiante.PrestamosActivos
                            </span>
                        </td>
                        <td>
                            <AuthorizeView Policy="@RoleConstants.Permissions.Estudiantes.Read">
                                <Authorized>
                                    <button class="btn btn-primary btn-sm me-1" @onclick="() => VerDetalles(estudiante.EstudianteId)">
                                        <i class="bi bi-eye"></i> Detalles
                                    </button>
                                </Authorized>
                            </AuthorizeView>
                            <AuthorizeView Policy="@RoleConstants.Permissions.Estudiantes.Update">
                                <Authorized>
                                    <button class="btn btn-warning btn-sm" @onclick="() => EditarEstudiante(estudiante.EstudianteId)">
                                        <i class="bi bi-pencil"></i> Editar
                                    </button>
                                </Authorized>
                            </AuthorizeView>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (errorMessage != null)
{
    <div class="alert alert-danger mt-3">
        @errorMessage
    </div>
}

@code {
    private IEnumerable<EstudianteDTO>? estudiantes;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await CargarEstudiantes();
    }

    private async Task CargarEstudiantes()
    {
        try
        {
            estudiantes = await EstudianteService.GetAllAsync();
            errorMessage = null;
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al cargar estudiantes: {ex.Message}";
        }
    }

    private void VerDetalles(int estudianteId)
    {
        NavigationManager.NavigateTo($"/estudiantes/{estudianteId}");
    }

    private void CrearEstudiante()
    {
        NavigationManager.NavigateTo("/estudiantes/crear");
    }

    private void EditarEstudiante(int estudianteId)
    {
        NavigationManager.NavigateTo($"/estudiantes/editar/{estudianteId}");
    }
}