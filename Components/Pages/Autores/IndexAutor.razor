@page "/autores"
@using Microsoft.AspNetCore.Authorization
@using LibroManager.Services.Interfaces
@using LibroManager.DTOs
@using LibroManager.Constants
@inject IAutorService AutorService
@inject NavigationManager NavigationManager
@attribute [Authorize(Policy = RoleConstants.Permissions.Autores.Read)]
@rendermode InteractiveServer

<PageTitle>Autores - LibroManager</PageTitle>

<h1>Catálogo de Autores</h1>

<AuthorizeView Policy="@RoleConstants.Permissions.Autores.Create">
    <Authorized>
        <div class="mb-3">
            <button class="btn btn-primary" @onclick="CrearAutor">
                <i class="bi bi-plus-circle"></i> Crear Autor
            </button>
        </div>
    </Authorized>
</AuthorizeView>

@if (autores == null)
{
    <p><em>Cargando...</em></p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Cantidad de Libros</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var autor in autores)
                {
                    <tr>
                        <td>@autor.Nombre</td>
                        <td>@autor.CantidadLibros</td>
                        <td>
                            <AuthorizeView Policy="@RoleConstants.Permissions.Autores.Read">
                                <Authorized>
                                    <button class="btn btn-primary btn-sm me-1" @onclick="() => VerDetalles(autor.AutorId)">
                                        <i class="bi bi-eye"></i> Detalles
                                    </button>
                                </Authorized>
                            </AuthorizeView>
                            <AuthorizeView Policy="@RoleConstants.Permissions.Autores.Update">
                                <Authorized>
                                    <button class="btn btn-warning btn-sm" @onclick="() => EditarAutor(autor.AutorId)">
                                        <i class="bi bi-pencil"></i> Editar
                                    </button>
                                </Authorized>
                            </AuthorizeView>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private IEnumerable<AutorDTO>? autores;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            autores = await AutorService.GetAllAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
            throw;
        }
    }

    private void VerDetalles(int autorId)
    {
        NavigationManager.NavigateTo($"/autores/{autorId}");
    }

    private void CrearAutor()
    {
        NavigationManager.NavigateTo("/autores/crear");
    }

    private void EditarAutor(int autorId)
    {
        NavigationManager.NavigateTo($"/autores/editar/{autorId}");
    }
}