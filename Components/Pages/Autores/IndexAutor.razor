@page "/autores"
@using Microsoft.AspNetCore.Authorization
@using LibroManager.Services.Interfaces
@using LibroManager.DTOs
@using LibroManager.Constants
@inject IAutorService AutorService
@inject ILibroService LibroService
@inject NavigationManager NavigationManager
@attribute [Authorize(Policy = RoleConstants.Permissions.Autores.Read)]
@rendermode InteractiveServer
<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<PageTitle>Autores - LibroManager</PageTitle>

<h1>Catálogo de Autores</h1>

<AuthorizeView Policy="@RoleConstants.Permissions.Autores.Create">
    <Authorized>
        <div class="mb-3">
            <button class="btn btn-primary" @onclick="CrearAutor">
                <i class="bi bi-plus-circle"></i> Crear Autor
            </button>
        </div>
    </Authorized>
</AuthorizeView>

@if (autores == null)
{
    <p><em>Cargando...</em></p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Cantidad de Títulos</th>
                    <th>Ejemplares</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var autor in autores)
                {
                    var totalEjemplares = ejemplaresPorAutor.TryGetValue(autor.AutorId, out var count) ? count : 0;
                    var prestados = ejemplaresPrestadosPorAutor.TryGetValue(autor.AutorId, out var prestadosCount) ? prestadosCount : 0;
                    var perdidos = ejemplaresPerdidosPorAutor.TryGetValue(autor.AutorId, out var perdidosCount) ? perdidosCount : 0;
                    var disponibles = totalEjemplares - prestados - perdidos;
                    var colorClass = disponibles > 0 ? "text-success" : "text-danger";

                    <tr>
                        <td>@autor.Nombre</td>
                        <td>@autor.CantidadLibros</td>
                        <td class="@(totalEjemplares > 0 ? colorClass : "")">
                            @if (totalEjemplares > 0)
                            {
                                <span>
                                    <strong>@disponibles</strong> disponibles 
                                    <span class="text-muted">|</span> 
                                    <span class="@(prestados > 0 ? "text-orange" : "")">@prestados prestados</span>
                                    <span class="text-muted">|</span> 
                                    <span class="@(perdidos > 0 ? "text-danger" : "")">@perdidos perdidos</span>
                                    <span class="text-muted">|</span> 
                                    @totalEjemplares total
                                </span>
                            }
                            else
                            {
                                <span>Sin ejemplares</span>
                            }
                        </td>
                        <td>
                            <AuthorizeView Policy="@RoleConstants.Permissions.Autores.Read">
                                <Authorized>
                                    <button class="btn btn-primary btn-sm me-1" @onclick="() => VerDetalles(autor.AutorId)">
                                        <i class="bi bi-eye"></i> Detalles
                                    </button>
                                </Authorized>
                            </AuthorizeView>
                            <AuthorizeView Policy="@RoleConstants.Permissions.Autores.Update">
                                <Authorized>
                                    <button class="btn btn-warning btn-sm" @onclick="() => EditarAutor(autor.AutorId)">
                                        <i class="bi bi-pencil"></i> Editar
                                    </button>
                                </Authorized>
                            </AuthorizeView>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private IEnumerable<AutorDTO>? autores;
    private Dictionary<int, int> ejemplaresPorAutor = new();
    private Dictionary<int, int> ejemplaresPrestadosPorAutor = new();
    private Dictionary<int, int> ejemplaresPerdidosPorAutor = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            autores = await AutorService.GetAllAsync();
            if (autores != null)
            {
                await CargarNumeroEjemplares();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
            throw;
        }
    }

    private async Task CargarNumeroEjemplares()
    {
        if (autores == null) return;
        
        foreach (var autor in autores)
        {
            var libros = await LibroService.GetLibrosByAutorIdAsync(autor.AutorId);
            var totalEjemplares = 0;
            var totalPrestados = 0;
            var totalPerdidos = 0;

            foreach (var libro in libros)
            {
                var count = await LibroService.ContarEjemplaresPorIsbnAsync(libro.ISBN);
                var prestados = await LibroService.ContarEjemplaresPrestadosPorIsbnAsync(libro.ISBN);
                var perdidos = await LibroService.ContarEjemplaresPerdidosPorIsbnAsync(libro.ISBN);

                totalEjemplares += count;
                totalPrestados += prestados;
                totalPerdidos += perdidos;
            }

            ejemplaresPorAutor[autor.AutorId] = totalEjemplares;
            ejemplaresPrestadosPorAutor[autor.AutorId] = totalPrestados;
            ejemplaresPerdidosPorAutor[autor.AutorId] = totalPerdidos;
        }
    }

    private void VerDetalles(int autorId)
    {
        NavigationManager.NavigateTo($"/autores/{autorId}");
    }

    private void CrearAutor()
    {
        NavigationManager.NavigateTo("/autores/crear");
    }

    private void EditarAutor(int autorId)
    {
        NavigationManager.NavigateTo($"/autores/editar/{autorId}");
    }
}