@page "/prestamos"
@using Microsoft.AspNetCore.Authorization
@using LibroManager.DTOs
@using LibroManager.Services.Interfaces
@using LibroManager.Models
@using LibroManager.Constants
@inject IPrestamoService PrestamoService
@inject NavigationManager NavigationManager
@attribute [Authorize(Policy = RoleConstants.Permissions.Prestamos.Read)]
@rendermode InteractiveServer

<PageTitle>Préstamos - LibroManager</PageTitle>
<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<div class="ma-4" style="height: calc(100vh - 140px); display: flex; flex-direction: column;">
    <div class="d-flex justify-space-between align-center mb-4">
        <MudText Typo="Typo.h4">Registro de Préstamos</MudText>
        <AuthorizeView Policy="@RoleConstants.Permissions.Prestamos.Create">
            <Authorized>
                <MudButton Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" OnClick="CrearPrestamo">
                    Nuevo Préstamo
                </MudButton>
            </Authorized>
        </AuthorizeView>
    </div>

    @if (_prestamos == null)
    {
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    }
    else
    {
        <MudTable Items="@_prestamos" Dense="true" Hover="true" Filter="FiltrarPrestamos"
                  T="PrestamoDTO" Elevation="0" Class="flex-grow-1" FixedHeader="true">
            <ToolBarContent>
                <MudTextField @bind-Value="_searchString" Placeholder="Buscar..." Adornment="Adornment.Start"
                            AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" Immediate="true"></MudTextField>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel T="PrestamoDTO" SortBy="x => x.LibroTitulo">Libro</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel T="PrestamoDTO" SortBy="x => x.LibroSerial">Serial</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel T="PrestamoDTO" SortBy="x => x.EstudianteNombre">Estudiante</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel T="PrestamoDTO" SortBy="x => x.FechaPrestamo">Fecha Préstamo</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel T="PrestamoDTO" SortBy="x => x.FechaVencimiento">Fecha Vencimiento</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel T="PrestamoDTO" SortBy="x => x.FechaDevolucion">Fecha Devolución</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel T="PrestamoDTO" SortBy="x => ObtenerEstadoParaOrdenamiento(x)">Estado</MudTableSortLabel></MudTh>
                <MudTh>Acciones</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Libro">@context.LibroTitulo</MudTd>
                <MudTd DataLabel="Serial">@(!string.IsNullOrEmpty(context.LibroSerial) ? context.LibroSerial : "No disponible")</MudTd>
                <MudTd DataLabel="Estudiante">@context.EstudianteNombre</MudTd>
                <MudTd DataLabel="Fecha Préstamo">@context.FechaPrestamo.ToShortDateString()</MudTd>
                <MudTd DataLabel="Fecha Vencimiento">
                    <MudText Color="@(context.FechaVencimiento < DateTime.Now && context.EstaActivo ? Color.Error : Color.Default)">
                        @context.FechaVencimiento.ToShortDateString()
                    </MudText>
                </MudTd>
                <MudTd DataLabel="Fecha Devolución">
                    @if (context.FechaDevolucion.HasValue)
                    {
                        @context.FechaDevolucion.Value.ToShortDateString()
                    }
                    else
                    {
                        <MudText>Pendiente</MudText>
                    }
                </MudTd>
                <MudTd DataLabel="Estado">
                    @{
                        var chipColor = context.EstaActivo ? Color.Warning :
                                      context.FechaDevolucion.HasValue ? Color.Success : Color.Error;
                        var estadoTexto = context.EstaActivo ? "Activo" :
                                        context.FechaDevolucion.HasValue ? "Concluido" : "Expirado";
                    }
                    <MudChip T="string" Color="chipColor" Size="Size.Small">@estadoTexto</MudChip>
                </MudTd>
                <MudTd>
                    <MudStack Row="true" Spacing="1">
                        <AuthorizeView Policy="@RoleConstants.Permissions.Prestamos.Read" Context="authView">
                            <Authorized>
                                <MudIconButton Icon="@Icons.Material.Filled.Visibility" Color="Color.Primary" Size="Size.Small"
                                             OnClick="@(() => VerDetalles(context.PrestamoId))"
                                             aria-label="Ver detalles" />
                            </Authorized>
                        </AuthorizeView>
                        <AuthorizeView Policy="@RoleConstants.Permissions.Prestamos.Update" Context="authEdit">
                            <Authorized>
                                @if (context.EstaActivo)
                                {
                                    <MudIconButton Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small"
                                                 OnClick="@(() => DevolverPrestamo(context))"
                                                 aria-label="Devolver préstamo" />
                                }
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Warning" Size="Size.Small"
                                             OnClick="@(() => EditarPrestamo(context.PrestamoId))"
                                             aria-label="Editar préstamo" />
                            </Authorized>
                        </AuthorizeView>
                    </MudStack>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager RowsPerPageString="Filas por página" />
            </PagerContent>
        </MudTable>
    }
</div>

<MudDialog Visible="@_mostrarConfirmacionDevolucion" Options="dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">Confirmar devolución</MudText>
    </TitleContent>
    <DialogContent>
        @if (_prestamoADevolver != null)
        {
            <MudText>¿Está seguro que desea devolver el siguiente libro?</MudText>
            <MudSimpleTable Dense="true">
                <tbody>
                    <tr>
                        <td>Título:</td>
                        <td>@_prestamoADevolver.LibroTitulo</td>
                    </tr>
                    <tr>
                        <td>Serial:</td>
                        <td>@_prestamoADevolver.LibroSerial</td>
                    </tr>
                    <tr>
                        <td>Estudiante:</td>
                        <td>@_prestamoADevolver.EstudianteNombre</td>
                    </tr>
                </tbody>
            </MudSimpleTable>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CancelarDevolucion">Cancelar</MudButton>
        <MudButton Color="Color.Success" Variant="Variant.Filled" OnClick="ConfirmarDevolucion">Confirmar</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private IEnumerable<PrestamoDTO>? _prestamos;
    private string _errorMessage = string.Empty;
    private bool _mostrarConfirmacionDevolucion;
    private PrestamoDTO? _prestamoADevolver;
    private string _searchString = "";
    private DialogOptions dialogOptions = new() { FullWidth = true };

    protected override async Task OnInitializedAsync()
    {
        await CargarPrestamos();
    }

    private async Task CargarPrestamos()
    {
        _prestamos = await PrestamoService.GetAllAsync();
    }

    private void CrearPrestamo()
    {
        NavigationManager.NavigateTo("/prestamos/crear");
    }

    private void VerDetalles(int prestamoId)
    {
        NavigationManager.NavigateTo($"/prestamos/{prestamoId}");
    }

    private void EditarPrestamo(int prestamoId)
    {
        NavigationManager.NavigateTo($"/prestamos/editar/{prestamoId}");
    }

    private void DevolverPrestamo(PrestamoDTO prestamo)
    {
        _prestamoADevolver = prestamo;
        _mostrarConfirmacionDevolucion = true;
    }

    private void CancelarDevolucion()
    {
        _mostrarConfirmacionDevolucion = false;
        _prestamoADevolver = null;
    }

    private async Task ConfirmarDevolucion()
    {
        if (_prestamoADevolver == null) return;

        try
        {
            var prestamoUpdateDto = new PrestamoUpdateDTO
            {
                PrestamoId = _prestamoADevolver.PrestamoId,
                LibroId = _prestamoADevolver.LibroId,
                EstudianteId = _prestamoADevolver.EstudianteId,
                FechaPrestamo = _prestamoADevolver.FechaPrestamo,
                FechaVencimiento = _prestamoADevolver.FechaVencimiento,
                FechaDevolucion = DateTime.Now,
                Estado = EstadoPrestamo.Concluido
            };

            var result = await PrestamoService.UpdateAsync(prestamoUpdateDto);
            if (result)
            {
                await CargarPrestamos();
            }
        }
        catch (Exception) { }
        finally
        {
            _mostrarConfirmacionDevolucion = false;
            _prestamoADevolver = null;
        }
    }

    private bool FiltrarPrestamos(PrestamoDTO prestamo)
    {
        if (string.IsNullOrWhiteSpace(_searchString)) return true;

        var estadoTexto = ObtenerTextoEstado(prestamo);

        return prestamo.LibroTitulo?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) == true ||
               prestamo.LibroSerial?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) == true ||
               prestamo.EstudianteNombre?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) == true ||
               estadoTexto.Contains(_searchString, StringComparison.OrdinalIgnoreCase);
    }

    private string ObtenerTextoEstado(PrestamoDTO prestamo)
    {
        if (prestamo == null) return string.Empty;
        
        if (prestamo.EstaActivo) return "Activo";
        if (prestamo.FechaDevolucion.HasValue) return "Concluido";
        return "Expirado";
    }

    private int ObtenerEstadoParaOrdenamiento(PrestamoDTO prestamo)
    {
        if (prestamo == null) return 0;
        
        if (prestamo.EstaActivo) return 1;
        if (prestamo.FechaDevolucion.HasValue) return 2;
        return 3;
    }
}