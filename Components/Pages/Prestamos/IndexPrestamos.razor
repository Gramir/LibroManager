@page "/prestamos"
@using Microsoft.AspNetCore.Authorization
@using LibroManager.DTOs
@using LibroManager.Services.Interfaces
@using LibroManager.Models
@using LibroManager.Constants
@inject IPrestamoService PrestamoService
@inject NavigationManager NavigationManager
@attribute [Authorize(Policy = RoleConstants.Permissions.Prestamos.Read)]
@rendermode InteractiveServer
@using System.Diagnostics

<PageTitle>Préstamos - LibroManager</PageTitle>

<h1>Préstamos</h1>

<AuthorizeView Policy="@RoleConstants.Permissions.Prestamos.Create">
    <Authorized>
        <div class="mb-3">
            <a href="/prestamos/crear" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Nuevo Préstamo
            </a>
        </div>
    </Authorized>
</AuthorizeView>

@if (_prestamos == null)
{
    <div class="d-flex justify-content-center">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Cargando...</span>
        </div>
    </div>
}
else if (!_prestamos.Any())
{
    <div class="alert alert-info" role="alert">
        No hay préstamos registrados.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Libro</th>
                    <th>Serial</th>
                    <th>Estudiante</th>
                    <th>Fecha de Préstamo</th>
                    <th>Fecha de Vencimiento</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var prestamo in _prestamos)
                {
                    <tr>
                        <td>@prestamo.LibroTitulo</td>
                        <td>@(!string.IsNullOrEmpty(prestamo.LibroSerial) ? prestamo.LibroSerial : "No disponible")</td>
                        <td>@prestamo.EstudianteNombre</td>
                        <td>@prestamo.FechaPrestamo.ToShortDateString()</td>
                        <td>
                            <span class="@(prestamo.FechaVencimiento < DateTime.Now && prestamo.EstaActivo ? "text-danger" : "")">
                                @prestamo.FechaVencimiento.ToShortDateString()
                            </span>
                        </td>
                        <td>
                            @{
                                string badgeClass;
                                string estadoTexto;
                                
                                if (prestamo.EstaActivo)
                                {
                                    badgeClass = "bg-warning";
                                    estadoTexto = "Activo";
                                }
                                else if (prestamo.FechaDevolucion.HasValue)
                                {
                                    badgeClass = "bg-success";
                                    estadoTexto = "Concluido";
                                }
                                else
                                {
                                    badgeClass = "bg-danger";
                                    estadoTexto = "Expirado";
                                }
                            }
                            <span class="badge @badgeClass">@estadoTexto</span>
                        </td>
                        <td>
                            <AuthorizeView Policy="@RoleConstants.Permissions.Prestamos.Read">
                                <Authorized>
                                    <a href="/prestamos/@prestamo.PrestamoId" class="btn btn-primary btn-sm me-2">
                                        <i class="bi bi-eye"></i> Detalles
                                    </a>
                                </Authorized>
                            </AuthorizeView>
                            <AuthorizeView Policy="@RoleConstants.Permissions.Prestamos.Update">
                                <Authorized>
                                    @if (prestamo.EstaActivo)
                                    {
                                        <button class="btn btn-success btn-sm me-2" @onclick="() => DevolverPrestamo(prestamo)">
                                            <i class="bi bi-check-circle"></i> Devolver
                                        </button>
                                    }
                                    <a href="/prestamos/editar/@prestamo.PrestamoId" class="btn btn-warning btn-sm">
                                        <i class="bi bi-pencil"></i> Editar
                                    </a>
                                </Authorized>
                            </AuthorizeView>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <div class="alert alert-danger mt-3">
        @_errorMessage
    </div>
}

@if (_mostrarConfirmacionDevolucion)
{
    <div class="modal fade show" style="display: block;" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirmar devolución</h5>
                    <button type="button" class="btn-close" @onclick="CancelarDevolucion"></button>
                </div>
                <div class="modal-body">
                    <p>¿Está seguro que desea devolver el siguiente libro?</p>
                    <dl class="row">
                        <dt class="col-sm-3">Título:</dt>
                        <dd class="col-sm-9">@_prestamoADevolver?.LibroTitulo</dd>
                        <dt class="col-sm-3">Serial:</dt>
                        <dd class="col-sm-9">@_prestamoADevolver?.LibroSerial</dd>
                        <dt class="col-sm-3">Estudiante:</dt>
                        <dd class="col-sm-9">@_prestamoADevolver?.EstudianteNombre</dd>
                    </dl>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CancelarDevolucion">Cancelar</button>
                    <button type="button" class="btn btn-success" @onclick="ConfirmarDevolucion">Confirmar</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@code {
    private IEnumerable<PrestamoDTO>? _prestamos;
    private string _errorMessage = string.Empty;
    private bool _mostrarConfirmacionDevolucion;
    private PrestamoDTO? _prestamoADevolver;

    protected override async Task OnInitializedAsync()
    {
        await CargarPrestamos();
    }

    private async Task CargarPrestamos()
    {
        _prestamos = await PrestamoService.GetAllAsync();
    }

    private void DevolverPrestamo(PrestamoDTO prestamo)
    {
        _prestamoADevolver = prestamo;
        _mostrarConfirmacionDevolucion = true;
    }

    private void CancelarDevolucion()
    {
        _mostrarConfirmacionDevolucion = false;
        _prestamoADevolver = null;
    }

    private async Task ConfirmarDevolucion()
    {
        if (_prestamoADevolver == null) return;

        try
        {
            var prestamoUpdateDto = new PrestamoUpdateDTO
            {
                PrestamoId = _prestamoADevolver.PrestamoId,
                LibroId = _prestamoADevolver.LibroId,
                EstudianteId = _prestamoADevolver.EstudianteId,
                FechaPrestamo = _prestamoADevolver.FechaPrestamo,
                FechaVencimiento = _prestamoADevolver.FechaVencimiento,
                FechaDevolucion = DateTime.Now,
                Estado = EstadoPrestamo.Concluido
            };

            var result = await PrestamoService.UpdateAsync(prestamoUpdateDto);
            if (result)
            {
                await CargarPrestamos();
            }
            else
            {
                _errorMessage = "No se pudo devolver el préstamo. Por favor, intente nuevamente.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error al devolver el préstamo: {ex.Message}";
        }
        finally
        {
            _mostrarConfirmacionDevolucion = false;
            _prestamoADevolver = null;
        }
    }
}