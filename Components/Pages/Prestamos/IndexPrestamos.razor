@page "/prestamos"
@using Microsoft.AspNetCore.Authorization
@using LibroManager.DTOs
@using LibroManager.Services.Interfaces
@using LibroManager.Models
@using LibroManager.Constants
@inject IPrestamoService PrestamoService
@inject NavigationManager NavigationManager
@attribute [Authorize(Policy = RoleConstants.Permissions.Prestamos.Read)]
@rendermode InteractiveServer
@using System.Diagnostics

<PageTitle>Préstamos - LibroManager</PageTitle>

<h1>Préstamos</h1>

<AuthorizeView Policy="@RoleConstants.Permissions.Prestamos.Create">
    <Authorized>
        <div class="mb-3">
            <a href="/prestamos/crear" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Nuevo Préstamo
            </a>
        </div>
    </Authorized>
</AuthorizeView>

@if (_prestamos == null)
{
    <div class="d-flex justify-content-center">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Cargando...</span>
        </div>
    </div>
}
else if (!_prestamos.Any())
{
    <div class="alert alert-info" role="alert">
        No hay préstamos registrados.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Libro</th>
                    <th>Serial</th>
                    <th>Estudiante</th>
                    <th>Fecha de Préstamo</th>
                    <th>Fecha de Vencimiento</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var prestamo in _prestamos)
                {
                    <tr>
                        <td>@prestamo.LibroTitulo</td>
                        <td>@(!string.IsNullOrEmpty(prestamo.LibroSerial) ? prestamo.LibroSerial : "No disponible")</td>
                        <td>@prestamo.EstudianteNombre</td>
                        <td>@prestamo.FechaPrestamo.ToShortDateString()</td>
                        <td>
                            <span class="@(prestamo.FechaVencimiento < DateTime.Now && prestamo.EstaActivo ? "text-danger" : "")">
                                @prestamo.FechaVencimiento.ToShortDateString()
                            </span>
                        </td>
                        <td>
                            @{
                                string badgeClass;
                                string estadoTexto;
                                
                                if (prestamo.EstaActivo)
                                {
                                    badgeClass = "bg-warning";
                                    estadoTexto = "Activo";
                                }
                                else if (prestamo.FechaDevolucion.HasValue)
                                {
                                    badgeClass = "bg-success";
                                    estadoTexto = "Concluido";
                                }
                                else
                                {
                                    badgeClass = "bg-danger";
                                    estadoTexto = "Expirado";
                                }
                            }
                            <span class="badge @badgeClass">@estadoTexto</span>
                        </td>
                        <td>
                            <AuthorizeView Policy="@RoleConstants.Permissions.Prestamos.Read">
                                <Authorized>
                                    <a href="/prestamos/@prestamo.PrestamoId" class="btn btn-primary btn-sm me-2">
                                        <i class="bi bi-eye"></i> Detalles
                                    </a>
                                </Authorized>
                            </AuthorizeView>
                            <AuthorizeView Policy="@RoleConstants.Permissions.Prestamos.Update">
                                <Authorized>
                                    <a href="/prestamos/editar/@prestamo.PrestamoId" class="btn btn-warning btn-sm">
                                        <i class="bi bi-pencil"></i> Editar
                                    </a>
                                </Authorized>
                            </AuthorizeView>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private IEnumerable<PrestamoDTO>? _prestamos;

    protected override async Task OnInitializedAsync()
    {
        _prestamos = await PrestamoService.GetAllAsync();
        
        // Código de depuración para comprobar los valores recibidos
        if (_prestamos != null && _prestamos.Any())
        {
            foreach (var prestamo in _prestamos)
            {
                Debug.WriteLine($"Préstamo {prestamo.PrestamoId} - Libro: {prestamo.LibroTitulo}, Serial: {prestamo.LibroSerial}");
            }
        }
    }
}