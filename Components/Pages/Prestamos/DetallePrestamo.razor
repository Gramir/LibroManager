@page "/prestamos/{PrestamoId:int}"
@using Microsoft.AspNetCore.Authorization
@using LibroManager.DTOs
@using LibroManager.Models
@using LibroManager.Services.Interfaces
@using LibroManager.Constants
@inject IPrestamoService PrestamoService
@inject NavigationManager NavigationManager
@attribute [Authorize(Policy = RoleConstants.Permissions.Prestamos.Read)]
@rendermode InteractiveServer
<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<PageTitle>Detalle del Préstamo</PageTitle>

<div class="container mt-4">
    @if (_prestamo == null)
    {
        <div class="d-flex justify-content-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h3 class="mb-0">Préstamo de Libro</h3>
                <div>
                    <AuthorizeView Policy="@RoleConstants.Permissions.Prestamos.Update">
                        <Authorized>
                            @if (_prestamo.EstaActivo)
                            {
                                <button class="btn btn-success me-2" @onclick="MostrarConfirmacionDevolucion">
                                    <i class="bi bi-check-circle"></i> Devolver
                                </button>
                            }
                            <button class="btn btn-warning me-2" @onclick="EditarPrestamo">
                                <i class="bi bi-pencil"></i> Editar
                            </button>
                        </Authorized>
                    </AuthorizeView>
                    <AuthorizeView Policy="@RoleConstants.Permissions.Prestamos.Delete">
                        <Authorized>
                            <button class="btn btn-danger me-2" @onclick="MostrarConfirmacionEliminacion" disabled="@(_prestamo.EstaActivo)">
                                <i class="bi bi-trash"></i> Eliminar
                            </button>
                        </Authorized>
                    </AuthorizeView>
                    <button class="btn btn-secondary" @onclick="Volver">
                        <i class="bi bi-arrow-left"></i> Volver
                    </button>
                    @if (_prestamo.EstaActivo)
                    {
                        <div class="text-danger mt-2 small">
                            <i class="bi bi-exclamation-circle"></i> No se puede eliminar un préstamo activo
                        </div>
                    }
                </div>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <dl class="row">
                            <dt class="col-sm-4">Libro:</dt>
                            <dd class="col-sm-8">@_prestamo.LibroTitulo</dd>

                            <dt class="col-sm-4">Serial:</dt>
                            <dd class="col-sm-8">@_prestamo.LibroSerial</dd>

                            <dt class="col-sm-4">Estudiante:</dt>
                            <dd class="col-sm-8">@_prestamo.EstudianteNombre</dd>

                            <dt class="col-sm-4">Fecha de Préstamo:</dt>
                            <dd class="col-sm-8">@_prestamo.FechaPrestamo.ToShortDateString()</dd>

                            <dt class="col-sm-4">Fecha de Vencimiento:</dt>
                            <dd class="col-sm-8">
                                <span class="@(_prestamo.FechaVencimiento < DateTime.Now && _prestamo.EstaActivo ? "text-danger" : "")">
                                    @_prestamo.FechaVencimiento.ToShortDateString()
                                </span>
                            </dd>

                            @if (_prestamo.FechaDevolucion.HasValue)
                            {
                                <dt class="col-sm-4">Fecha de Devolución:</dt>
                                <dd class="col-sm-8">@_prestamo.FechaDevolucion.Value.ToShortDateString()</dd>
                            }

                            <dt class="col-sm-4">Estado:</dt>
                            <dd class="col-sm-8">
                                @{
                                    string badgeClass;
                                    string estadoTexto;
                                    
                                    if (_prestamo.EstaActivo)
                                    {
                                        badgeClass = "bg-warning";
                                        estadoTexto = "Activo";
                                    }
                                    else if (_prestamo.FechaDevolucion.HasValue)
                                    {
                                        badgeClass = "bg-success";
                                        estadoTexto = "Concluido";
                                    }
                                    else
                                    {
                                        badgeClass = "bg-danger";
                                        estadoTexto = "Expirado";
                                    }
                                }
                                <span class="badge @badgeClass">@estadoTexto</span>
                            </dd>
                        </dl>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger mt-3">
            @_errorMessage
        </div>
    }
</div>

@if (_mostrarConfirmacionEliminacion)
{
    <div class="modal fade show" style="display: block;" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirmar eliminación</h5>
                    <button type="button" class="btn-close" @onclick="CancelarEliminacion"></button>
                </div>
                <div class="modal-body">
                    ¿Está seguro que desea eliminar este préstamo?
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CancelarEliminacion">Cancelar</button>
                    <button type="button" class="btn btn-danger" @onclick="EliminarPrestamo">Confirmar</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@if (_mostrarConfirmacionDevolucion)
{
    <div class="modal fade show" style="display: block;" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirmar devolución</h5>
                    <button type="button" class="btn-close" @onclick="CancelarDevolucion"></button>
                </div>
                <div class="modal-body">
                    <p>¿Está seguro que desea devolver el siguiente libro?</p>
                    <dl class="row">
                        <dt class="col-sm-3">Título:</dt>
                        <dd class="col-sm-9">@_prestamo?.LibroTitulo</dd>
                        <dt class="col-sm-3">Serial:</dt>
                        <dd class="col-sm-9">@_prestamo?.LibroSerial</dd>
                        <dt class="col-sm-3">Estudiante:</dt>
                        <dd class="col-sm-9">@_prestamo?.EstudianteNombre</dd>
                    </dl>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CancelarDevolucion">Cancelar</button>
                    <button type="button" class="btn btn-success" @onclick="ConfirmarDevolucion">Confirmar</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@code {
    [Parameter]
    public int PrestamoId { get; set; }

    private PrestamoDTO? _prestamo;
    private string _errorMessage = string.Empty;
    private bool _mostrarConfirmacionEliminacion;
    private bool _mostrarConfirmacionDevolucion;

    protected override async Task OnInitializedAsync()
    {
        _prestamo = await PrestamoService.GetByIdAsync(PrestamoId);
        if (_prestamo == null)
        {
            NavigationManager.NavigateTo("/prestamos");
            return;
        }
    }

    private void EditarPrestamo()
    {
        NavigationManager.NavigateTo($"/prestamos/editar/{PrestamoId}");
    }

    private void Volver()
    {
        NavigationManager.NavigateTo("/prestamos");
    }

    private void MostrarConfirmacionEliminacion()
    {
        _mostrarConfirmacionEliminacion = true;
    }

    private void CancelarEliminacion()
    {
        _mostrarConfirmacionEliminacion = false;
    }

    private void MostrarConfirmacionDevolucion()
    {
        _mostrarConfirmacionDevolucion = true;
    }

    private void CancelarDevolucion()
    {
        _mostrarConfirmacionDevolucion = false;
    }

    private async Task ConfirmarDevolucion()
    {
        if (_prestamo == null) return;

        try
        {
            var prestamoUpdateDto = new PrestamoUpdateDTO
            {
                PrestamoId = _prestamo.PrestamoId,
                LibroId = _prestamo.LibroId,
                EstudianteId = _prestamo.EstudianteId,
                FechaPrestamo = _prestamo.FechaPrestamo,
                FechaVencimiento = _prestamo.FechaVencimiento,
                FechaDevolucion = DateTime.Now,
                Estado = EstadoPrestamo.Concluido
            };

            var result = await PrestamoService.UpdateAsync(prestamoUpdateDto);
            if (result)
            {
                // Recargar el préstamo para mostrar los cambios
                _prestamo = await PrestamoService.GetByIdAsync(PrestamoId);
            }
            else
            {
                _errorMessage = "No se pudo devolver el préstamo. Por favor, intente nuevamente.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error al devolver el préstamo: {ex.Message}";
        }
        finally
        {
            _mostrarConfirmacionDevolucion = false;
        }
    }

    private async Task EliminarPrestamo()
    {
        _mostrarConfirmacionEliminacion = false;
        
        try
        {
            var result = await PrestamoService.DeleteAsync(PrestamoId);
            if (result)
            {
                NavigationManager.NavigateTo("/prestamos");
            }
            else
            {
                _errorMessage = "No se pudo eliminar el préstamo. Puede que esté activo o ya no exista.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error al eliminar el préstamo: {ex.Message}";
        }
    }
}