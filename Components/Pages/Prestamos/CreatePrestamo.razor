@page "/prestamos/crear"
@page "/prestamos/crear/{LibroId:int?}"
@using LibroManager.Services.Interfaces
@using LibroManager.DTOs
@inject IPrestamoService PrestamoService
@inject ILibroService LibroService
@inject IEstudianteService EstudianteService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Crear Préstamo - LibroManager</PageTitle>

<div class="container">
    <h1>Crear Nuevo Préstamo</h1>

    <div class="row">
        <div class="col-md-6">
            <EditForm Model="@prestamoDto" OnValidSubmit="@HandleValidSubmit">
                <DataAnnotationsValidator />

                <div class="mb-3">
                    <label for="titulo" class="form-label">Título del Libro</label>
                    <InputSelect id="titulo" @bind-Value="selectedIsbn" @oninput="OnLibroSeleccionado" class="@GetTituloClasses()">
                        <option value="">Seleccione un libro...</option>
                        @if (LibrosUnicos != null)
                        {
                            @foreach (var libro in LibrosUnicos)
                            {
                                <option value="@libro.ISBN">@libro.Titulo</option>
                            }
                        }
                    </InputSelect>
                </div>

                <div class="mb-3">
                    <label for="ejemplar" class="form-label">Ejemplar</label>
                    <InputSelect id="ejemplar" @bind-Value="prestamoDto.LibroId" disabled="@(string.IsNullOrEmpty(selectedIsbn))" class="@GetEjemplarClasses()">
                        <option value="0">Seleccione un ejemplar...</option>
                        @if (EjemplaresDisponibles != null)
                        {
                            @foreach (var ejemplar in EjemplaresDisponibles)
                            {
                                <option value="@ejemplar.LibroId">@ejemplar.Serial (Ubicación: @ejemplar.UbicacionFormateada)</option>
                            }
                        }
                    </InputSelect>
                    <ValidationMessage For="@(() => prestamoDto.LibroId)" />
                </div>

                <div class="mb-3">
                    <label for="estudiante" class="form-label">Estudiante</label>
                    <InputSelect id="estudiante" @bind-Value="prestamoDto.EstudianteId" class="@GetEstudianteClasses()">
                        <option value="0">Seleccione un estudiante...</option>
                        @if (Estudiantes != null)
                        {
                            @foreach (var estudiante in Estudiantes)
                            {
                                <option value="@estudiante.EstudianteId">@estudiante.Nombre (@estudiante.Email)</option>
                            }
                        }
                    </InputSelect>
                    <ValidationMessage For="@(() => prestamoDto.EstudianteId)" />
                </div>

                <div class="mb-3">
                    <label for="fechaVencimiento" class="form-label">Fecha de Vencimiento</label>
                    <InputDate id="fechaVencimiento" @bind-Value="prestamoDto.FechaVencimiento" class="@GetFechaVencimientoClasses()" />
                    <ValidationMessage For="@(() => prestamoDto.FechaVencimiento)" />
                </div>

                <div class="mb-3">
                    <button type="submit" class="btn btn-primary me-2">
                        <i class="bi bi-save"></i> Guardar
                    </button>
                    <button type="button" class="btn btn-secondary" @onclick="@Cancelar">
                        <i class="bi bi-x-circle"></i> Cancelar
                    </button>
                </div>
            </EditForm>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger mt-3">
                    @errorMessage
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter]
    public int? LibroId { get; set; }

    private PrestamoCreateDTO prestamoDto = new()
    {
        FechaVencimiento = DateTime.Now.AddDays(7)
    };
    private IEnumerable<LibroDTO>? Libros;
    private IEnumerable<LibroDTO>? LibrosUnicos;
    private IEnumerable<LibroDTO>? EjemplaresDisponibles;
    private IEnumerable<EstudianteDTO>? Estudiantes;
    private string errorMessage = string.Empty;
    private string selectedIsbn = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Cargar primero todos los estudiantes
            Estudiantes = await EstudianteService.GetAllAsync();

            var todosLosLibros = await LibroService.GetAllLibrosAsync();
            
            if (todosLosLibros != null)
            {
                // Crear una lista de libros únicos por ISBN
                LibrosUnicos = todosLosLibros.GroupBy(l => l.ISBN)
                                  .Select(g => g.First())
                                  .ToList();

                Libros = todosLosLibros;
            }

            // Si tenemos un LibroId, buscar ese libro específico primero
            if (LibroId.HasValue)
            {
                var libroSeleccionado = Libros?.FirstOrDefault(l => l.LibroId == LibroId.Value);
                if (libroSeleccionado == null)
                {
                    errorMessage = "El libro seleccionado no existe.";
                    return;
                }
                
                if (libroSeleccionado.EstaPrestado)
                {
                    errorMessage = "El libro seleccionado no está disponible para préstamo.";
                    return;
                }

                // Preseleccionar el ISBN y cargar los ejemplares disponibles
                selectedIsbn = libroSeleccionado.ISBN;
                await CargarEjemplaresDisponibles();
                
                // Asignar el libro seleccionado al DTO
                prestamoDto.LibroId = LibroId.Value;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al cargar los datos: {ex.Message}";
        }
    }

    private async Task OnLibroSeleccionado(ChangeEventArgs e)
    {
        selectedIsbn = e.Value?.ToString() ?? string.Empty;
        
        // Resetear el LibroId cuando cambie la selección
        prestamoDto.LibroId = 0;
        
        await CargarEjemplaresDisponibles();
    }

    private async Task CargarEjemplaresDisponibles()
    {
        if (string.IsNullOrEmpty(selectedIsbn))
        {
            EjemplaresDisponibles = Array.Empty<LibroDTO>();
            return;
        }

        // Cargar todos los ejemplares para el ISBN seleccionado
        var ejemplares = await LibroService.GetEjemplaresPorIsbnAsync(selectedIsbn);
        
        // Filtrar solo los ejemplares disponibles
        EjemplaresDisponibles = ejemplares.Where(e => !e.EstaPrestado).ToList();
    }

    private async Task HandleValidSubmit()
    {
        try
        {
            var result = await PrestamoService.CreateAsync(prestamoDto);
            if (result)
            {
                NavigationManager.NavigateTo("/prestamos");
            }
            else
            {
                errorMessage = "No se pudo crear el préstamo. Verifique que el libro esté disponible y el estudiante no tenga préstamos vencidos.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
    }

    private void Cancelar()
    {
        NavigationManager.NavigateTo("/prestamos");
    }

    private bool IsValidFechaVencimiento()
    {
        return prestamoDto.FechaVencimiento > DateTime.Now;
    }

    private string GetTituloClasses()
    {
        return $"form-select{(string.IsNullOrEmpty(selectedIsbn) ? " is-invalid" : "")}";
    }

    private string GetEjemplarClasses()
    {
        return $"form-select{(prestamoDto.LibroId == 0 ? " is-invalid" : "")}";
    }

    private string GetEstudianteClasses()
    {
        return $"form-select{(prestamoDto.EstudianteId == 0 ? " is-invalid" : "")}";
    }

    private string GetFechaVencimientoClasses()
    {
        return $"form-control{(!IsValidFechaVencimiento() ? " is-invalid" : "")}";
    }
}