@page "/libros/editar/{LibroId:int}"
@using Microsoft.AspNetCore.Authorization
@using LibroManager.Services.Interfaces
@using LibroManager.DTOs
@using LibroManager.Constants
@inject ILibroService LibroService
@inject IAutorService AutorService
@inject ICategoriaService CategoriaService
@inject IUbicacionService UbicacionService
@inject NavigationManager NavigationManager
@attribute [Authorize(Policy = RoleConstants.Permissions.Libros.Update)]
@rendermode InteractiveServer

<PageTitle>Editar Libro - LibroManager</PageTitle>

<style>
    .dropdown-container {
        position: relative;
    }
    .dropdown-menu {
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        z-index: 1000;
        display: none;
        max-height: 200px;
        overflow-y: auto;
        padding: 0.5rem 0;
        margin: 0;
        background-color: #fff;
        border: 1px solid rgba(0,0,0,.15);
        border-radius: 0.25rem;
    }
    .dropdown-menu.show {
        display: block;
    }
    .dropdown-item {
        display: block;
        width: 100%;
        padding: 0.25rem 1rem;
        clear: both;
        font-weight: 400;
        color: #212529;
        text-align: inherit;
        text-decoration: none;
        white-space: nowrap;
        background-color: transparent;
        border: 0;
    }
    .dropdown-item:hover {
        background-color: #f8f9fa;
        cursor: pointer;
    }
</style>

<div class="container">
    @if (LibroDto == null)
    {
        <div class="d-flex justify-content-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h1>Editar Libro</h1>
                    <button class="btn btn-secondary" @onclick="Volver">Volver</button>
                </div>

                <EditForm Model="LibroDto" OnValidSubmit="HandleValidSubmit">
                    <DataAnnotationsValidator />

                    <div class="mb-3">
                        <label for="titulo" class="form-label">Título</label>
                        <InputText id="titulo" class="form-control" @bind-Value="LibroDto.Titulo" />
                        <ValidationMessage For="@(() => LibroDto.Titulo)" />
                    </div>

                    <div class="mb-3">
                        <label for="isbn" class="form-label">ISBN</label>
                        <InputText id="isbn" class="form-control" @bind-Value="LibroDto.ISBN" disabled />
                        <small class="text-muted">El ISBN no se puede modificar</small>
                    </div>

                    <div class="mb-3">
                        <label for="serial" class="form-label">Número de Serie</label>
                        <InputText id="serial" class="form-control" @bind-Value="LibroDto.Serial" disabled />
                        <small class="text-muted">El número de serie no se puede modificar</small>
                    </div>

                    <div class="mb-3">
                        <label for="autor" class="form-label">Autor</label>
                        <InputSelect id="autor" class="form-select" @bind-Value="LibroDto.AutorId">
                            <option value="0">Seleccione un autor...</option>
                            @if (Autores != null)
                            {
                                @foreach (var autor in Autores)
                                {
                                    <option value="@autor.AutorId">@autor.Nombre</option>
                                }
                            }
                        </InputSelect>
                        <ValidationMessage For="@(() => LibroDto.AutorId)" />
                    </div>

                    <div class="mb-3">
                        <label for="categoria" class="form-label">Categoría</label>
                        <InputSelect id="categoria" class="form-select" @bind-Value="LibroDto.CategoriaId">
                            <option value="0">Seleccione una categoría...</option>
                            @if (Categorias != null)
                            {
                                @foreach (var categoria in Categorias)
                                {
                                    <option value="@categoria.CategoriaId">@categoria.Nombre</option>
                                }
                            }
                        </InputSelect>
                        <ValidationMessage For="@(() => LibroDto.CategoriaId)" />
                    </div>

                    <div class="mb-3 dropdown-container" @onclick:stopPropagation>
                        <label for="ubicacion" class="form-label">Ubicación</label>
                        <div class="input-group">
                            <InputText id="ubicacion" 
                                    class="form-control" 
                                    @bind-Value="LibroDto.UbicacionString"
                                    @oninput="FilterUbicaciones"
                                    @onfocus="ShowDropdown"
                                    @onblur="async () => await OnBlur()"
                                    placeholder="Escriba para filtrar ubicaciones..." />
                        </div>
                        <div class="dropdown-menu @(_showDropdown ? "show" : "")">
                            @if (_ubicacionesFiltradas != null && _ubicacionesFiltradas.Any())
                            {
                                @foreach (var ubicacion in _ubicacionesFiltradas)
                                {
                                    <div class="dropdown-item" 
                                        @onmousedown="@(() => SelectUbicacion(ubicacion.UbicacionFormateada))">
                                        @ubicacion.UbicacionFormateada
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="dropdown-item">No se encontraron ubicaciones</div>
                            }
                        </div>
                        @if (_ubicaciones != null && !_ubicaciones.Any())
                        {
                            <div class="alert alert-warning mt-2">
                                No hay ubicaciones disponibles. Por favor, libere alguna ubicación antes de continuar.
                            </div>
                        }
                        <ValidationMessage For="@(() => LibroDto.UbicacionString)" />
                    </div>

                    <div class="mb-3">
                        <button type="submit" class="btn btn-primary me-2">Guardar Cambios</button>
                        <button type="button" class="btn btn-secondary" @onclick="Volver">Cancelar</button>
                    </div>
                </EditForm>

                @if (!string.IsNullOrEmpty(ErrorMessage))
                {
                    <div class="alert alert-danger mt-3">
                        @ErrorMessage
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public int LibroId { get; set; }

    private LibroUpdateDTO? LibroDto { get; set; }
    private IEnumerable<AutorDTO>? Autores { get; set; }
    private IEnumerable<CategoriaDTO>? Categorias { get; set; }
    private IEnumerable<UbicacionDTO>? _ubicaciones;
    private IEnumerable<UbicacionDTO>? _ubicacionesFiltradas;
    private string ErrorMessage { get; set; } = string.Empty;
    private bool _showDropdown;

    protected override async Task OnInitializedAsync()
    {
        var libro = await LibroService.GetLibroByIdAsync(LibroId);
        if (libro == null)
        {
            NavigationManager.NavigateTo("/libros");
            return;
        }

        LibroDto = new LibroUpdateDTO
        {
            LibroId = libro.LibroId,
            Titulo = libro.Titulo,
            ISBN = libro.ISBN,
            Serial = libro.Serial,
            AutorId = 0,
            CategoriaId = 0,
            UbicacionString = libro.UbicacionFormateada
        };

        Autores = await AutorService.GetAllAsync();
        Categorias = await CategoriaService.GetAllAsync();
        await LoadUbicaciones();
        _ubicacionesFiltradas = _ubicaciones;
        
        if (Autores != null)
        {
            var autor = Autores.FirstOrDefault(a => a.Nombre == libro.AutorNombre);
            if (autor != null)
            {
                LibroDto.AutorId = autor.AutorId;
            }
        }

        if (Categorias != null)
        {
            var categoria = Categorias.FirstOrDefault(c => c.Nombre == libro.CategoriaNombre);
            if (categoria != null)
            {
                LibroDto.CategoriaId = categoria.CategoriaId;
            }
        }
    }

    private async Task LoadUbicaciones()
    {
        if (_ubicaciones == null)
        {
            _ubicaciones = await UbicacionService.GetAvailableUbicacionesWithCurrentAsync(LibroId);
        }
    }

    private void FilterUbicaciones(ChangeEventArgs e)
    {
        var searchText = e.Value?.ToString()?.ToLower() ?? string.Empty;
        
        if (string.IsNullOrWhiteSpace(searchText))
        {
            _ubicacionesFiltradas = _ubicaciones;
        }
        else
        {
            _ubicacionesFiltradas = _ubicaciones?
                .Where(u => u.UbicacionFormateada.ToLower().Contains(searchText))
                .ToList();
        }
        _showDropdown = true;

        // Validar si el texto actual no coincide con ninguna ubicación disponible
        if (_ubicaciones != null && !string.IsNullOrWhiteSpace(searchText) && LibroDto != null &&
            !_ubicaciones.Any(u => u.UbicacionFormateada.Equals(LibroDto.UbicacionString, StringComparison.OrdinalIgnoreCase)))
        {
            ErrorMessage = "Por favor, seleccione una ubicación válida del listado desplegable.";
        }
        else
        {
            ErrorMessage = string.Empty;
        }
    }

    private void ShowDropdown()
    {
        _showDropdown = true;
    }

    private void SelectUbicacion(string ubicacion)
    {
        if (LibroDto != null)
        {
            LibroDto.UbicacionString = ubicacion;
        }
        _showDropdown = false;
        ErrorMessage = string.Empty; // Limpiar mensaje de error cuando se selecciona una ubicación válida
    }

    private async Task OnBlur()
    {
        await Task.Delay(150);
        _showDropdown = false;
        StateHasChanged();
    }

    private async Task HandleValidSubmit()
    {
        if (LibroDto == null) return;

        try
        {
            // Verificar si la ubicación seleccionada está en la lista de ubicaciones disponibles
            if (_ubicaciones == null || !_ubicaciones.Any(u => u.UbicacionFormateada == LibroDto.UbicacionString))
            {
                ErrorMessage = "Debe seleccionar una ubicación válida del listado desplegable.";
                return;
            }

            // Actualizar el libro actual y todos los ejemplares (autor y categoría)
            var updateResult = await LibroService.UpdateLibroAsync(LibroDto);
            if (updateResult)
            {
                // Si la actualización fue exitosa, actualizar los campos compartidos de todos los ejemplares
                await LibroService.UpdateEjemplaresCompartidosAsync(LibroDto.ISBN, LibroDto.AutorId, LibroDto.CategoriaId);
                NavigationManager.NavigateTo("/libros");
            }
            else
            {
                ErrorMessage = "No se pudo actualizar el libro. Por favor, verifique los datos e intente nuevamente.";
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Error al actualizar el libro: {ex.Message}";
        }
    }

    private void Volver()
    {
        NavigationManager.NavigateTo("/libros");
    }
}