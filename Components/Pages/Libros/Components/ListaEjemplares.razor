@using LibroManager.DTOs
@using LibroManager.Constants
@using Microsoft.AspNetCore.Components

<div class="mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4>Lista de Ejemplares</h4>
        <AuthorizeView Policy="@RoleConstants.Permissions.Libros.Create">
            <Authorized>
                <button class="btn btn-primary" @onclick="OnCrearEjemplar">
                    <i class="bi bi-plus-circle"></i> Crear Ejemplar
                </button>
            </Authorized>
        </AuthorizeView>
    </div>
    <div class="table-responsive">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Serial</th>
                    <th>Ubicación</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ejemplar in Ejemplares.OrderBy(e => e.Serial))
                {
                    <tr>
                        <td>@ejemplar.Serial</td>
                        <td>@ejemplar.UbicacionFormateada</td>
                        <td>
                            <span class="badge @GetEstadoBadgeClass(ejemplar)">
                                @GetEstadoText(ejemplar)
                            </span>
                        </td>
                        <td>
                            @if (ejemplar.EstaPrestado || ejemplar.EstaPerdido)
                            {
                                <AuthorizeView Policy="@RoleConstants.Permissions.Prestamos.Read">
                                    <Authorized>
                                        <button class="btn btn-info btn-sm me-2" @onclick="() => OnVerPrestamo(ejemplar.LibroId)">
                                            <i class="bi bi-eye"></i> Ver préstamo
                                        </button>
                                    </Authorized>
                                </AuthorizeView>
                            }
                            @if (!ejemplar.EstaPrestado && !ejemplar.EstaPerdido)
                            {
                                <AuthorizeView Policy="@RoleConstants.Permissions.Prestamos.Create">
                                    <Authorized>
                                        <button class="btn btn-success btn-sm me-2" @onclick="() => OnPrestarLibro(ejemplar.LibroId)">
                                            <i class="bi bi-book"></i> Prestar
                                        </button>
                                    </Authorized>
                                </AuthorizeView>
                            }
                            <AuthorizeView Policy="@RoleConstants.Permissions.Libros.Update">
                                <Authorized>
                                    <button class="btn btn-warning btn-sm me-2" @onclick="() => OnEditarEjemplar(ejemplar)"
                                            disabled="@ejemplar.EstaPrestado">
                                        <i class="bi bi-pencil"></i> Editar
                                    </button>
                                </Authorized>
                            </AuthorizeView>
                            <AuthorizeView Policy="@RoleConstants.Permissions.Libros.Delete">
                                <Authorized>
                                    <button class="btn btn-danger btn-sm" @onclick="() => OnEliminarEjemplar(ejemplar)"
                                            disabled="@ejemplar.EstaPrestado">
                                        <i class="bi bi-trash"></i> Eliminar
                                    </button>
                                </Authorized>
                            </AuthorizeView>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    [Parameter]
    public IEnumerable<LibroDTO> Ejemplares { get; set; } = default!;

    [Parameter]
    public EventCallback OnCrearEjemplarClick { get; set; }

    [Parameter]
    public EventCallback<int> OnVerPrestamoClick { get; set; }

    [Parameter]
    public EventCallback<int> OnPrestarLibroClick { get; set; }

    [Parameter]
    public EventCallback<LibroDTO> OnEditarEjemplarClick { get; set; }

    [Parameter]
    public EventCallback<LibroDTO> OnEliminarEjemplarClick { get; set; }

    private string GetEstadoBadgeClass(LibroDTO ejemplar)
    {
        if (ejemplar.EstaPerdido)
            return "bg-danger";
        if (ejemplar.EstaPrestado)
            return "bg-warning";
        return "bg-success";
    }

    private string GetEstadoText(LibroDTO ejemplar)
    {
        if (ejemplar.EstaPerdido)
            return "Perdido";
        if (ejemplar.EstaPrestado)
            return "Prestado";
        return "Disponible";
    }

    private Task OnCrearEjemplar() => OnCrearEjemplarClick.InvokeAsync();
    private Task OnVerPrestamo(int libroId) => OnVerPrestamoClick.InvokeAsync(libroId);
    private Task OnPrestarLibro(int libroId) => OnPrestarLibroClick.InvokeAsync(libroId);
    private Task OnEditarEjemplar(LibroDTO ejemplar) => OnEditarEjemplarClick.InvokeAsync(ejemplar);
    private Task OnEliminarEjemplar(LibroDTO ejemplar) => OnEliminarEjemplarClick.InvokeAsync(ejemplar);
}