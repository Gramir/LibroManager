@using LibroManager.DTOs

@if (Visible)
{
    <div class="modal fade show" style="display: block;" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirmar eliminación</h5>
                    <button type="button" class="btn-close" @onclick="OnCancelar"></button>
                </div>
                <div class="modal-body">
                    @if (EjemplarAEliminar != null)
                    {
                        @if (TienePrestamosHistoricos)
                        {
                            <p>El ejemplar '@EjemplarAEliminar.Serial' tiene préstamos históricos.</p>
                            <p>¿Desea eliminar el ejemplar y todo su historial de préstamos?</p>
                        }
                        else
                        {
                            <p>¿Está seguro que desea eliminar el ejemplar con serial '@EjemplarAEliminar.Serial'?</p>
                        }
                    }
                    else
                    {
                        <p>¿Está seguro que desea eliminar el libro '@Libro?.Titulo' y todos sus ejemplares?</p>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="OnCancelar">Cancelar</button>
                    <button type="button" class="btn btn-danger" @onclick="OnConfirmar">Confirmar</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@code {
    [Parameter]
    public bool Visible { get; set; }

    [Parameter]
    public LibroDTO? Libro { get; set; }

    [Parameter]
    public LibroDTO? EjemplarAEliminar { get; set; }

    [Parameter]
    public bool TienePrestamosHistoricos { get; set; }

    [Parameter]
    public EventCallback OnCancelarClick { get; set; }

    [Parameter]
    public EventCallback OnConfirmarClick { get; set; }

    private Task OnCancelar() => OnCancelarClick.InvokeAsync();
    private Task OnConfirmar() => OnConfirmarClick.InvokeAsync();
}