@page "/libros/{LibroId:int}"
@using LibroManager.DTOs
@using LibroManager.Services.Interfaces
@inject ILibroService LibroService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Detalle del Libro</PageTitle>

<div class="container mt-4">
    @if (_libro == null)
    {
        <div class="d-flex justify-content-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h3 class="mb-0">@_libro.Titulo</h3>
                <div>
                    <button class="btn btn-warning me-2" @onclick="EditarLibro">Editar</button>
                    <button class="btn btn-danger me-2" @onclick="MostrarConfirmacion" disabled="@_ejemplares.Any()">
                        Eliminar
                    </button>
                    <button class="btn btn-secondary" @onclick="Volver">Volver</button>
                </div>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <dl class="row">
                            <dt class="col-sm-4">ISBN:</dt>
                            <dd class="col-sm-8">@_libro.ISBN</dd>

                            <dt class="col-sm-4">Autor:</dt>
                            <dd class="col-sm-8">@_libro.AutorNombre</dd>

                            <dt class="col-sm-4">Categoría:</dt>
                            <dd class="col-sm-8">@_libro.CategoriaNombre</dd>

                            <dt class="col-sm-4">Ejemplares:</dt>
                            <dd class="col-sm-8">@_ejemplares.Count()</dd>
                        </dl>
                    </div>
                </div>

                @if (_ejemplares.Any())
                {
                    <div class="mt-4">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h4>Lista de Ejemplares</h4>
                            <button class="btn btn-primary" @onclick="MostrarFormularioEjemplar">
                                <i class="bi bi-plus-circle"></i> Crear Ejemplar
                            </button>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-striped">
                                <thead>
                                    <tr>
                                        <th>Serial</th>
                                        <th>Ubicación</th>
                                        <th>Estado</th>
                                        <th>Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var ejemplar in _ejemplares.OrderBy(e => e.Serial))
                                    {
                                        <tr>
                                            <td>@ejemplar.Serial</td>
                                            <td>@ejemplar.UbicacionFormateada</td>
                                            <td>
                                                <span class="badge @(ejemplar.EstaPrestado ? "bg-warning" : "bg-success")">
                                                    @(ejemplar.EstaPrestado ? "Prestado" : "Disponible")
                                                </span>
                                            </td>
                                            <td>
                                                <button class="btn btn-success btn-sm me-2" 
                                                        @onclick="() => PrestarLibro(ejemplar.LibroId)"
                                                        disabled="@ejemplar.EstaPrestado">
                                                    <i class="bi bi-book"></i> Prestar
                                                </button>
                                                <button class="btn btn-danger btn-sm" 
                                                        @onclick="() => MostrarConfirmacionEjemplar(ejemplar)"
                                                        disabled="@ejemplar.EstaPrestado">
                                                    <i class="bi bi-trash"></i> Eliminar
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
                else
                {
                    <div class="mt-4">
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle"></i> No hay ejemplares registrados para este libro.
                        </div>
                        <button class="btn btn-primary" @onclick="MostrarFormularioEjemplar">
                            <i class="bi bi-plus-circle"></i> Crear Ejemplar
                        </button>
                    </div>
                }
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger mt-3">
            @_errorMessage
        </div>
    }
</div>

@if (_mostrarFormularioEjemplar)
{
    <div class="modal fade show" style="display: block;" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Crear Nuevo Ejemplar</h5>
                    <button type="button" class="btn-close" @onclick="CerrarFormularioEjemplar"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Título del Libro</label>
                        <input type="text" class="form-control" value="@_libro?.Titulo" readonly />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">ISBN</label>
                        <input type="text" class="form-control" value="@_libro?.ISBN" readonly />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Serial a Asignar</label>
                        <input type="text" class="form-control" value="@($"{_libro?.ISBN}-{_ejemplares.Count() + 1}")" readonly />
                    </div>
                    <div class="mb-3">
                        <label for="ubicacion" class="form-label">Ubicación (formato: A-1-1)</label>
                        <input type="text" class="form-control" id="ubicacion" @bind="_nuevaUbicacion" placeholder="Ejemplo: A-1-1" />
                        <small class="form-text text-muted">Formato: Estante(A-Z)-Nivel(1-10)-Posición(1-50)</small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CerrarFormularioEjemplar">Cancelar</button>
                    <button type="button" class="btn btn-primary" @onclick="CrearEjemplar" disabled="@string.IsNullOrWhiteSpace(_nuevaUbicacion)">
                        Crear
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@if (_mostrarConfirmacion)
{
    <div class="modal fade show" style="display: block;" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirmar eliminación</h5>
                    <button type="button" class="btn-close" @onclick="CancelarEliminacion"></button>
                </div>
                <div class="modal-body">
                    @if (_ejemplarAEliminar != null)
                    {
                        <p>¿Está seguro que desea eliminar el ejemplar con serial '@_ejemplarAEliminar.Serial'?</p>
                    }
                    else
                    {
                        <p>¿Está seguro que desea eliminar el libro '@_libro?.Titulo' y todos sus ejemplares?</p>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CancelarEliminacion">Cancelar</button>
                    <button type="button" class="btn btn-danger" @onclick="EliminarLibro">Confirmar</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@code {
    [Parameter]
    public int LibroId { get; set; }

    private LibroDTO? _libro;
    private IEnumerable<LibroDTO> _ejemplares = Enumerable.Empty<LibroDTO>();
    private string _errorMessage = string.Empty;
    private bool _mostrarConfirmacion;
    private LibroDTO? _ejemplarAEliminar;
    private bool _mostrarFormularioEjemplar;
    private string _nuevaUbicacion = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        _libro = await LibroService.GetLibroByIdAsync(LibroId);
        if (_libro == null)
        {
            NavigationManager.NavigateTo("/libros");
            return;
        }

        _ejemplares = await LibroService.GetEjemplaresPorIsbnAsync(_libro.ISBN);
    }

    private void Volver()
    {
        NavigationManager.NavigateTo("/libros");
    }

    private void EditarLibro()
    {
        NavigationManager.NavigateTo($"/libros/editar/{LibroId}");
    }

    private void MostrarConfirmacion()
    {
        if (_ejemplares.Any())
        {
            _errorMessage = "No se puede eliminar el libro mientras tenga ejemplares. Elimine los ejemplares primero.";
            return;
        }
        _ejemplarAEliminar = null;
        _mostrarConfirmacion = true;
    }

    private void MostrarConfirmacionEjemplar(LibroDTO ejemplar)
    {
        if (ejemplar.EstaPrestado)
        {
            _errorMessage = "No se puede eliminar un ejemplar que está prestado.";
            return;
        }
        _ejemplarAEliminar = ejemplar;
        _mostrarConfirmacion = true;
    }

    private void CancelarEliminacion()
    {
        _mostrarConfirmacion = false;
        _ejemplarAEliminar = null;
    }

    private async Task EliminarLibro()
    {
        _mostrarConfirmacion = false;
        
        try
        {
            bool result;
            if (_ejemplarAEliminar != null)
            {
                result = await LibroService.DeleteLibroAsync(_ejemplarAEliminar.LibroId);
                if (result)
                {
                    // Actualizar la lista de ejemplares
                    _ejemplares = await LibroService.GetEjemplaresPorIsbnAsync(_libro!.ISBN);
                    if (!_ejemplares.Any())
                    {
                        // Si era el último ejemplar, volver a la lista
                        NavigationManager.NavigateTo("/libros");
                    }
                }
                else
                {
                    _errorMessage = "No se pudo eliminar el ejemplar. Puede que esté prestado o ya no exista.";
                }
            }
            else
            {
                result = await LibroService.DeleteLibroAsync(LibroId);
                if (result)
                {
                    NavigationManager.NavigateTo("/libros");
                }
                else
                {
                    _errorMessage = "No se pudo eliminar el libro. Puede que ya no exista.";
                }
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error al eliminar: {ex.Message}";
        }
        finally
        {
            _ejemplarAEliminar = null;
        }
    }

    private bool TieneEjemplaresPrestados()
    {
        return _ejemplares.Any(e => e.EstaPrestado);
    }

    private void MostrarFormularioEjemplar()
    {
        _mostrarFormularioEjemplar = true;
        _nuevaUbicacion = string.Empty;
    }

    private void CerrarFormularioEjemplar()
    {
        _mostrarFormularioEjemplar = false;
        _nuevaUbicacion = string.Empty;
    }

    private async Task CrearEjemplar()
    {
        if (string.IsNullOrWhiteSpace(_nuevaUbicacion) || _libro == null)
            return;

        try
        {
            var result = await LibroService.CreateEjemplarAsync(_libro.ISBN, _nuevaUbicacion);
            if (result)
            {
                _ejemplares = await LibroService.GetEjemplaresPorIsbnAsync(_libro.ISBN);
                CerrarFormularioEjemplar();
            }
            else
            {
                _errorMessage = "No se pudo crear el ejemplar. Por favor, intente nuevamente.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error al crear el ejemplar: {ex.Message}";
        }
    }

    private void PrestarLibro(int libroId)
    {
        NavigationManager.NavigateTo($"/prestamos/crear/{libroId}");
    }
}