@page "/libros/{LibroId:int}"
@using Microsoft.AspNetCore.Authorization
@using LibroManager.Services.Interfaces
@using LibroManager.DTOs
@using LibroManager.Constants
@using LibroManager.Components.Pages.Libros.Components
@inject ILibroService LibroService
@inject IPrestamoService PrestamoService
@inject IUbicacionService UbicacionService
@inject NavigationManager NavigationManager
@attribute [Authorize(Policy = RoleConstants.Permissions.Libros.Read)]
@rendermode InteractiveServer

<div class="container mt-4">
    @if (_libro == null)
    {
        <div class="d-flex justify-content-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h3 class="mb-0">@_libro.Titulo</h3>
                <div>
                    <AuthorizeView Policy="@RoleConstants.Permissions.Libros.Update">
                        <Authorized>
                            <button class="btn btn-warning me-2" @onclick="EditarLibro">Editar</button>
                        </Authorized>
                    </AuthorizeView>
                    <AuthorizeView Policy="@RoleConstants.Permissions.Libros.Delete">
                        <Authorized>
                            <button class="btn btn-danger me-2" @onclick="MostrarConfirmacion" disabled="@_ejemplares.Any()">
                                Eliminar
                            </button>
                        </Authorized>
                    </AuthorizeView>
                    <button class="btn btn-secondary" @onclick="Volver">Volver</button>
                </div>
            </div>
            <div class="card-body">
                <InfoLibro Libro="_libro" CantidadEjemplares="_ejemplares.Count()" />

                @if (_ejemplares.Any())
                {
                    <ListaEjemplares 
                        Ejemplares="_ejemplares"
                        OnCrearEjemplarClick="MostrarFormularioEjemplar"
                        OnVerPrestamoClick="VerPrestamo"
                        OnPrestarLibroClick="PrestarLibro"
                        OnEditarEjemplarClick="MostrarFormularioEditarEjemplar"
                        OnEliminarEjemplarClick="MostrarConfirmacionEjemplar" />
                }
                else
                {
                    <div class="mt-4">
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle"></i> No hay ejemplares registrados para este libro.
                        </div>
                        <AuthorizeView Policy="@RoleConstants.Permissions.Libros.Create">
                            <Authorized>
                                <button class="btn btn-primary" @onclick="MostrarFormularioEjemplar">
                                    <i class="bi bi-plus-circle"></i> Crear Ejemplar
                                </button>
                            </Authorized>
                        </AuthorizeView>
                    </div>
                }
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger mt-3">
            @_errorMessage
        </div>
    }
</div>

<CrearEjemplarModal 
    Visible="_mostrarFormularioEjemplar"
    Libro="_libro"
    NumeroEjemplar="_ejemplares.Count() + 1"
    UbicacionSeleccionada="_nuevaUbicacion"
    UbicacionSeleccionadaChanged="(ubicacion) => _nuevaUbicacion = ubicacion"
    Ubicaciones="_ubicaciones"
    UbicacionesFiltradas="_ubicacionesFiltradas"
    ShowDropdown="_showDropdown"
    ShowDropdownChanged="(show) => _showDropdown = show"
    ErrorMessageUbicacion="_errorMessageUbicacion"
    OnCancelarClick="CerrarFormularioEjemplar"
    OnGuardarClick="CrearEjemplar"
    OnUbicacionInputChange="OnUbicacionInput" />

<EditarEjemplarModal 
    Visible="_mostrarFormularioEditarEjemplar"
    Libro="_libro"
    Ejemplar="_ejemplarEditar"
    UbicacionSeleccionada="_nuevaUbicacion"
    UbicacionSeleccionadaChanged="(ubicacion) => _nuevaUbicacion = ubicacion"
    UbicacionesFiltradas="_ubicacionesFiltradas"
    ShowDropdown="_showDropdown"
    ShowDropdownChanged="(show) => _showDropdown = show"
    ErrorMessageUbicacion="_errorMessageUbicacion"
    OnCancelarClick="CerrarFormularioEditarEjemplar"
    OnGuardarClick="GuardarEjemplar"
    OnUbicacionInputChange="OnUbicacionInput" />

<ConfirmarEliminacionModal 
    Visible="_mostrarConfirmacion"
    Libro="_libro"
    EjemplarAEliminar="_ejemplarAEliminar"
    TienePrestamosHistoricos="_tienePrestamosHistoricos"
    OnCancelarClick="CancelarEliminacion"
    OnConfirmarClick="EliminarLibro" />

@code {
    [Parameter]
    public int LibroId { get; set; }

    private LibroDTO? _libro;
    private IEnumerable<LibroDTO> _ejemplares = Enumerable.Empty<LibroDTO>();
    private string _errorMessage = string.Empty;
    private bool _mostrarConfirmacion;
    private LibroDTO? _ejemplarAEliminar;
    private bool _mostrarFormularioEjemplar;
    private bool _mostrarFormularioEditarEjemplar;
    private LibroDTO? _ejemplarEditar;
    private string _nuevaUbicacion = string.Empty;
    private bool _showDropdown;
    private IEnumerable<UbicacionDTO>? _ubicaciones;
    private IEnumerable<UbicacionDTO>? _ubicacionesFiltradas;
    private string _errorMessageUbicacion = string.Empty;
    private bool _tienePrestamosHistoricos;

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        try
        {
            _libro = await LibroService.GetLibroByIdAsync(LibroId);
            if (_libro == null)
            {
                NavigationManager.NavigateTo("/libros");
                return;
            }

            _ejemplares = await LibroService.GetEjemplaresPorIsbnAsync(_libro.ISBN);
            await LoadUbicaciones();
            _ubicacionesFiltradas = _ubicaciones;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error al cargar los datos: {ex.Message}";
        }
    }

    private async Task LoadUbicaciones()
    {
        if (_ejemplarEditar != null)
        {
            _ubicaciones = await UbicacionService.GetAvailableUbicacionesWithCurrentAsync(_ejemplarEditar.LibroId);
        }
        else
        {
            _ubicaciones = await UbicacionService.GetAvailableUbicacionesAsync();
        }
    }

    private void Volver() => NavigationManager.NavigateTo("/libros");
    private void EditarLibro() => NavigationManager.NavigateTo($"/libros/editar/{LibroId}");
    private void PrestarLibro(int libroId) => NavigationManager.NavigateTo($"/prestamos/crear/{libroId}");

    private void MostrarFormularioEjemplar()
    {
        _mostrarFormularioEjemplar = true;
        _nuevaUbicacion = string.Empty;
        _showDropdown = false;
    }

    private void CerrarFormularioEjemplar()
    {
        _mostrarFormularioEjemplar = false;
        _nuevaUbicacion = string.Empty;
    }

    private void MostrarFormularioEditarEjemplar(LibroDTO ejemplar)
    {
        _ejemplarEditar = ejemplar;
        _mostrarFormularioEditarEjemplar = true;
        _nuevaUbicacion = ejemplar.UbicacionFormateada;
        _showDropdown = false;
    }

    private void CerrarFormularioEditarEjemplar()
    {
        _mostrarFormularioEditarEjemplar = false;
        _nuevaUbicacion = string.Empty;
    }

    private void OnUbicacionInput(ChangeEventArgs e)
    {
        _nuevaUbicacion = e.Value?.ToString() ?? string.Empty;
        FilterUbicaciones(e);
    }

    private void FilterUbicaciones(ChangeEventArgs e)
    {
        var searchText = e.Value?.ToString()?.ToLower() ?? string.Empty;
        
        if (string.IsNullOrWhiteSpace(searchText))
        {
            _ubicacionesFiltradas = _ubicaciones;
        }
        else
        {
            _ubicacionesFiltradas = _ubicaciones?
                .Where(u => u.UbicacionFormateada.ToLower().Contains(searchText))
                .ToList();
        }
        _showDropdown = true;
    }

    private void ShowDropdown() => _showDropdown = true;

    private async Task OnBlur()
    {
        await Task.Delay(150);
        _showDropdown = false;
    }

    private async Task CrearEjemplar()
    {
        if (string.IsNullOrWhiteSpace(_nuevaUbicacion) || _libro == null) return;

        try
        {
            var result = await LibroService.CreateEjemplarAsync(_libro.ISBN, _nuevaUbicacion);
            if (result)
            {
                await CargarDatos();
                CerrarFormularioEjemplar();
            }
            else
            {
                _errorMessage = "No se pudo crear el ejemplar.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error al crear el ejemplar: {ex.Message}";
        }
    }

    private async Task GuardarEjemplar()
    {
        if (string.IsNullOrWhiteSpace(_nuevaUbicacion) || _ejemplarEditar == null) return;

        try
        {
            var result = await LibroService.UpdateEjemplarAsync(_ejemplarEditar.LibroId, _nuevaUbicacion);
            if (result)
            {
                await CargarDatos();
                CerrarFormularioEditarEjemplar();
            }
            else
            {
                _errorMessage = "No se pudo actualizar el ejemplar.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error al actualizar el ejemplar: {ex.Message}";
        }
    }

    private void MostrarConfirmacion()
    {
        if (_ejemplares.Any())
        {
            _errorMessage = "No se puede eliminar el libro mientras tenga ejemplares.";
            return;
        }
        _ejemplarAEliminar = null;
        _mostrarConfirmacion = true;
    }

    private async Task MostrarConfirmacionEjemplar(LibroDTO ejemplar)
    {
        var (puedeEliminar, tienePrestamosHistoricos) = await LibroService.PuedeEliminarLibroAsync(ejemplar.LibroId);
        
        if (!puedeEliminar && !tienePrestamosHistoricos)
        {
            _errorMessage = "No se puede eliminar un ejemplar que tiene préstamos activos.";
            return;
        }

        _ejemplarAEliminar = ejemplar;
        _tienePrestamosHistoricos = tienePrestamosHistoricos;
        _mostrarConfirmacion = true;
    }

    private async Task EliminarLibro()
    {
        try
        {
            bool result;
            if (_ejemplarAEliminar != null)
            {
                result = await LibroService.DeleteLibroAsync(_ejemplarAEliminar.LibroId, _tienePrestamosHistoricos);
                if (result)
                {
                    await CargarDatos();
                }
            }
            else
            {
                result = await LibroService.DeleteLibroAsync(LibroId);
                if (result)
                {
                    NavigationManager.NavigateTo("/libros");
                    return;
                }
            }

            if (!result)
            {
                _errorMessage = "No se pudo eliminar el elemento seleccionado.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error al eliminar: {ex.Message}";
        }
        finally
        {
            _mostrarConfirmacion = false;
            _ejemplarAEliminar = null;
            _tienePrestamosHistoricos = false;
        }
    }

    private void CancelarEliminacion()
    {
        _mostrarConfirmacion = false;
        _ejemplarAEliminar = null;
        _tienePrestamosHistoricos = false;
    }

    private async Task VerPrestamo(int libroId)
    {
        try
        {
            var prestamos = await PrestamoService.GetPrestamosByLibroAsync(libroId);
            var prestamo = prestamos?.OrderByDescending(p => p.FechaVencimiento).FirstOrDefault();
                              
            if (prestamo != null)
            {
                NavigationManager.NavigateTo($"/prestamos/{prestamo.PrestamoId}");
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error al obtener el préstamo: {ex.Message}";
        }
    }
}