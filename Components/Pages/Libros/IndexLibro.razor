@page "/libros"
@using LibroManager.Services.Interfaces
@using LibroManager.DTOs
@inject ILibroService LibroService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Libros - LibroManager</PageTitle>

<h1>Catálogo de Libros</h1>

<div class="mb-3">
    <button class="btn btn-primary" @onclick="CrearLibro">
        <i class="bi bi-plus-circle"></i> Crear Libro
    </button>
</div>

@if (libros == null)
{
    <p><em>Cargando...</em></p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Título</th>
                    <th>ISBN</th>
                    <th>Ejemplares</th>
                    <th>Autor</th>
                    <th>Categoría</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var libro in librosUnicos)
                {
                    <tr>
                        <td>@libro.Titulo</td>
                        <td>@libro.ISBN</td>
                        <td>@(ejemplaresPorIsbn.TryGetValue(libro.ISBN, out var count) ? count : 0)</td>
                        <td>@libro.AutorNombre</td>
                        <td>@libro.CategoriaNombre</td>
                        <td>
                            <button class="btn btn-primary btn-sm me-1" @onclick="() => VerDetalles(libro.LibroId)">
                                <i class="bi bi-eye"></i> Detalles
                            </button>
                            <button class="btn btn-warning btn-sm" @onclick="() => EditarLibro(libro.LibroId)">
                                <i class="bi bi-pencil"></i> Editar
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<LibroDTO>? libros;
    private List<LibroDTO> librosUnicos = new();
    private Dictionary<string, int> ejemplaresPorIsbn = new Dictionary<string, int>();

    protected override async Task OnInitializedAsync()
    {
        libros = (await LibroService.GetAllLibrosAsync()).ToList();
        if (libros != null)
        {
            // Agrupar por ISBN y tomar el primer libro de cada grupo
            librosUnicos = libros.GroupBy(l => l.ISBN)
                                .Select(g => g.First())
                                .ToList();
        }
        await CargarNumeroEjemplares();
    }

    private async Task CargarNumeroEjemplares()
    {
        if (libros == null) return;
        
        // Agrupar libros por ISBN para evitar llamadas duplicadas
        var isbnsUnicos = libros.Select(l => l.ISBN).Distinct();
        
        foreach (var isbn in isbnsUnicos)
        {
            var count = await LibroService.ContarEjemplaresPorIsbnAsync(isbn);
            ejemplaresPorIsbn[isbn] = count;
        }
    }

    private void VerDetalles(int libroId)
    {
        NavigationManager.NavigateTo($"/libros/{libroId}");
    }

    private void CrearLibro()
    {
        NavigationManager.NavigateTo("/libros/crear");
    }

    private void EditarLibro(int libroId)
    {
        NavigationManager.NavigateTo($"/libros/editar/{libroId}");
    }
}