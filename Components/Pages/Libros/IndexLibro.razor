@page "/libros"
@using LibroManager.Services.Interfaces
@using LibroManager.DTOs
@inject ILibroService LibroService
@inject NavigationManager NavigationManager

<PageTitle>Libros - LibroManager</PageTitle>

<h1>Catálogo de Libros</h1>

@if (libros == null)
{
    <p><em>Cargando...</em></p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Título</th>
                    <th>ISBN</th>
                    <th>Autor</th>
                    <th>Categoría</th>
                    <th>Ejemplares</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var libro in libros)
                {
                    <tr>
                        <td>@libro.Titulo</td>
                        <td>@libro.ISBN</td>
                        <td>@libro.AutorNombre</td>
                        <td>@libro.CategoriaNombre</td>
                        <td>@libro.NumeroEjemplares</td>
                        <td>
                            @if (libro.EstaPrestado)
                            {
                                <span class="badge bg-warning">Prestado</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Disponible</span>
                            }
                        </td>
                        <td>
                            <button class="btn btn-primary btn-sm" @onclick="() => VerDetalles(libro.LibroId)">
                                Detalles
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<LibroDTO>? libros;

    protected override async Task OnInitializedAsync()
    {
        libros = (await LibroService.GetAllLibrosAsync()).ToList();
    }

    private void VerDetalles(int libroId)
    {
        NavigationManager.NavigateTo($"/libros/{libroId}");
    }
}