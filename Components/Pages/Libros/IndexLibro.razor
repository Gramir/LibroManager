@page "/libros"
@using Microsoft.AspNetCore.Authorization
@using LibroManager.Services.Interfaces
@using LibroManager.DTOs
@using LibroManager.Constants
@inject ILibroService LibroService
@inject NavigationManager NavigationManager
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>Libros - LibroManager</PageTitle>

<h1>Catálogo de Libros</h1>

<div class="mb-3">
    <button class="btn btn-primary" @onclick="CrearLibro">
        <i class="bi bi-plus-circle"></i> Crear Libro
    </button>
</div>

@if (libros == null)
{
    <p><em>Cargando...</em></p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Título</th>
                    <th>ISBN</th>
                    <th>Ejemplares</th>
                    <th>Autor</th>
                    <th>Categoría</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var libro in librosUnicos)
                {
                    var totalEjemplares = ejemplaresPorIsbn.TryGetValue(libro.ISBN, out var count) ? count : 0;
                    var prestados = ejemplaresPrestadosPorIsbn.TryGetValue(libro.ISBN, out var prestadosCount) ? prestadosCount : 0;
                    var perdidos = ejemplaresPerdidosPorIsbn.TryGetValue(libro.ISBN, out var perdidosCount) ? perdidosCount : 0;
                    var disponibles = totalEjemplares - prestados - perdidos;
                    var colorClass = disponibles > 0 ? "text-success" : "text-danger";

                    <tr>
                        <td>@libro.Titulo</td>
                        <td>@libro.ISBN</td>
                        <td class="@colorClass">
                            <strong>@disponibles</strong> disponibles 
                            <span class="text-muted">|</span> 
                            <span class="@(prestados > 0 ? "text-orange" : "")">@prestados prestados</span>
                            <span class="text-muted">|</span> 
                            <span class="@(perdidos > 0 ? "text-danger" : "")">@perdidos perdidos</span>
                            <span class="text-muted">|</span> 
                            @totalEjemplares total
                        </td>
                        <td>@libro.AutorNombre</td>
                        <td>@libro.CategoriaNombre</td>
                        <td>
                            <button class="btn btn-primary btn-sm me-1" @onclick="() => VerDetalles(libro.LibroId)">
                                <i class="bi bi-eye"></i> Detalles
                            </button>
                            <button class="btn btn-warning btn-sm me-1" @onclick="() => EditarLibro(libro.LibroId)">
                                <i class="bi bi-pencil"></i> Editar
                            </button>
                            <button class="btn btn-success btn-sm" @onclick="() => PrestarLibro(libro.LibroId)"
                                    disabled="@(disponibles <= 0)">
                                <i class="bi bi-book"></i> Prestar
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<LibroDTO>? libros;
    private List<LibroDTO> librosUnicos = new();
    private Dictionary<string, int> ejemplaresPorIsbn = new();
    private Dictionary<string, int> ejemplaresPrestadosPorIsbn = new();
    private Dictionary<string, int> ejemplaresPerdidosPorIsbn = new();

    protected override async Task OnInitializedAsync()
    {
        libros = (await LibroService.GetAllLibrosAsync()).ToList();
        if (libros != null)
        {
            librosUnicos = libros.GroupBy(l => l.ISBN)
                                .Select(g => g.First())
                                .ToList();
        }
        await CargarNumeroEjemplares();
    }

    private async Task CargarNumeroEjemplares()
    {
        if (libros == null) return;
        
        var isbnsUnicos = libros.Select(l => l.ISBN).Distinct();
        
        foreach (var isbn in isbnsUnicos)
        {
            var count = await LibroService.ContarEjemplaresPorIsbnAsync(isbn);
            ejemplaresPorIsbn[isbn] = count;
            
            var prestados = await LibroService.ContarEjemplaresPrestadosPorIsbnAsync(isbn);
            ejemplaresPrestadosPorIsbn[isbn] = prestados;

            var perdidos = await LibroService.ContarEjemplaresPerdidosPorIsbnAsync(isbn);
            ejemplaresPerdidosPorIsbn[isbn] = perdidos;
        }
    }

    private void VerDetalles(int libroId)
    {
        NavigationManager.NavigateTo($"/libros/{libroId}");
    }

    private void CrearLibro()
    {
        NavigationManager.NavigateTo("/libros/crear");
    }

    private void EditarLibro(int libroId)
    {
        NavigationManager.NavigateTo($"/libros/editar/{libroId}");
    }

    private void PrestarLibro(int libroId)
    {
        // Obtener el libro seleccionado
        var libro = libros?.FirstOrDefault(l => l.LibroId == libroId);
        if (libro == null) return;

        // Buscar un ejemplar disponible del mismo ISBN
        var ejemplarDisponible = libros?.FirstOrDefault(l => 
            l.ISBN == libro.ISBN && 
            !l.EstaPrestado);

        if (ejemplarDisponible != null)
        {
            NavigationManager.NavigateTo($"/prestamos/crear/{ejemplarDisponible.LibroId}");
        }
    }
}