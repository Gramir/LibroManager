@page "/libros/crear"
@using LibroManager.Services.Interfaces
@using LibroManager.DTOs
@using LibroManager.Models
@inject ILibroService LibroService
@inject IAutorService AutorService
@inject ICategoriaService CategoriaService
@inject IUbicacionService UbicacionService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Crear Libro - LibroManager</PageTitle>

<style>
    .dropdown-container {
        position: relative;
    }
    .dropdown-menu {
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        z-index: 1000;
        display: none;
        max-height: 200px;
        overflow-y: auto;
        padding: 0.5rem 0;
        margin: 0;
        background-color: #fff;
        border: 1px solid rgba(0,0,0,.15);
        border-radius: 0.25rem;
    }
    .dropdown-menu.show {
        display: block;
    }
    .dropdown-item {
        display: block;
        width: 100%;
        padding: 0.25rem 1rem;
        clear: both;
        font-weight: 400;
        color: #212529;
        text-align: inherit;
        text-decoration: none;
        white-space: nowrap;
        background-color: transparent;
        border: 0;
    }
    .dropdown-item:hover {
        background-color: #f8f9fa;
        cursor: pointer;
    }
</style>

<div class="container">
    <h1>Crear Nuevo Libro</h1>

    <EditForm Model="@libroDto" OnValidSubmit="@HandleValidSubmit">
        <DataAnnotationsValidator />

        <div class="mb-3">
            <label for="titulo" class="form-label">Título</label>
            <InputText id="titulo" class="form-control" @bind-Value="@libroDto.Titulo" />
            <ValidationMessage For="@(() => libroDto.Titulo)" />
        </div>

        <div class="mb-3">
            <label for="isbn" class="form-label">ISBN</label>
            <InputText id="isbn" class="form-control" @bind-Value="@libroDto.ISBN" />
            <ValidationMessage For="@(() => libroDto.ISBN)" />
        </div>

        <div class="mb-3">
            <label for="autor" class="form-label">Autor</label>
            <InputSelect id="autor" class="form-select" @bind-Value="@libroDto.AutorId">
                <option value="0">Seleccione un autor...</option>
                @if (_autores != null)
                {
                    @foreach (var autor in _autores)
                    {
                        <option value="@autor.AutorId">@autor.Nombre</option>
                    }
                }
            </InputSelect>
            <ValidationMessage For="@(() => libroDto.AutorId)" />
        </div>

        <div class="mb-3">
            <label for="categoria" class="form-label">Categoría</label>
            <InputSelect id="categoria" class="form-select" @bind-Value="@libroDto.CategoriaId">
                <option value="0">Seleccione una categoría...</option>
                @if (_categorias != null)
                {
                    @foreach (var categoria in _categorias)
                    {
                        <option value="@categoria.CategoriaId">@categoria.Nombre</option>
                    }
                }
            </InputSelect>
            <ValidationMessage For="@(() => libroDto.CategoriaId)" />
        </div>

        <div class="mb-3 dropdown-container" @onclick:stopPropagation>
            <label for="ubicacion" class="form-label">Ubicación</label>
            <div class="input-group">
                <InputText id="ubicacion" 
                          class="form-control" 
                          @bind-Value="libroDto.UbicacionString"
                          @oninput="FilterUbicaciones"
                          @onfocus="ShowDropdown"
                          @onblur="async () => await OnBlur()"
                          placeholder="Escriba para filtrar ubicaciones..." />
            </div>
            <div class="dropdown-menu @(_showDropdown ? "show" : "")">
                @if (_ubicacionesFiltradas != null && _ubicacionesFiltradas.Any())
                {
                    @foreach (var ubicacion in _ubicacionesFiltradas)
                    {
                        <div class="dropdown-item" 
                             @onmousedown="@(() => SelectUbicacion(ubicacion.UbicacionFormateada))">
                            @ubicacion.UbicacionFormateada
                        </div>
                    }
                }
                else
                {
                    <div class="dropdown-item">No se encontraron ubicaciones</div>
                }
            </div>
            @if (_ubicaciones != null && !_ubicaciones.Any())
            {
                <div class="alert alert-warning mt-2">
                    No hay ubicaciones disponibles. Por favor, libere alguna ubicación antes de agregar un nuevo libro.
                </div>
            }
            <ValidationMessage For="@(() => libroDto.UbicacionString)" />
        </div>

        <div class="mb-3">
            <button type="submit" class="btn btn-primary me-2">Guardar</button>
            <button type="button" class="btn btn-secondary" @onclick="@(() => Cancelar())">Cancelar</button>
        </div>
    </EditForm>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger mt-3">
            @_errorMessage
        </div>
    }
</div>

@code {
    private readonly LibroCreateDTO libroDto = new();
    private IEnumerable<AutorDTO>? _autores;
    private IEnumerable<CategoriaDTO>? _categorias;
    private IEnumerable<UbicacionDTO>? _ubicaciones;
    private string _errorMessage = string.Empty;
    private bool _showDropdown;
    private IEnumerable<UbicacionDTO>? _ubicacionesFiltradas;

    protected override async Task OnInitializedAsync()
    {
        _autores = await AutorService.GetAllAsync();
        _categorias = await CategoriaService.GetAllAsync();
        await LoadUbicaciones();
        _ubicacionesFiltradas = _ubicaciones;
    }

    private async Task LoadUbicaciones()
    {
        if (_ubicaciones == null)
        {
            _ubicaciones = await UbicacionService.GetAvailableUbicacionesAsync();
        }
    }

    private async Task HandleValidSubmit()
    {
        try
        {
            if (await LibroService.ExisteIsbnAsync(libroDto.ISBN))
            {
                _errorMessage = "Ya existe un libro con este ISBN.";
                return;
            }

            // Verificar si la ubicación seleccionada está en la lista de ubicaciones disponibles
            if (_ubicaciones == null || !_ubicaciones.Any(u => u.UbicacionFormateada == libroDto.UbicacionString))
            {
                _errorMessage = "Debe seleccionar una ubicación válida del listado desplegable.";
                return;
            }

            var result = await LibroService.CreateLibroAsync(libroDto);
            if (result)
            {
                NavigationManager.NavigateTo("/libros");
            }
            else
            {
                _errorMessage = "No se pudo crear el libro. Por favor, verifique los datos e intente nuevamente.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error al crear el libro: {ex.Message}";
        }
    }

    private void Cancelar()
    {
        NavigationManager.NavigateTo("/libros");
    }

    private void FilterUbicaciones(ChangeEventArgs e)
    {
        var searchText = e.Value?.ToString()?.ToLower() ?? string.Empty;
        
        if (string.IsNullOrWhiteSpace(searchText))
        {
            _ubicacionesFiltradas = _ubicaciones;
        }
        else
        {
            _ubicacionesFiltradas = _ubicaciones?
                .Where(u => u.UbicacionFormateada.ToLower().Contains(searchText))
                .ToList();
        }
        _showDropdown = true;

        // Validar si el texto actual no coincide con ninguna ubicación disponible
        if (_ubicaciones != null && !string.IsNullOrWhiteSpace(searchText) && 
            !_ubicaciones.Any(u => u.UbicacionFormateada.Equals(libroDto.UbicacionString, StringComparison.OrdinalIgnoreCase)))
        {
            _errorMessage = "Por favor, seleccione una ubicación válida del listado desplegable.";
        }
        else
        {
            _errorMessage = string.Empty;
        }
    }

    private void ShowDropdown()
    {
        _showDropdown = true;
    }

    private void SelectUbicacion(string ubicacion)
    {
        libroDto.UbicacionString = ubicacion;
        _showDropdown = false;
        _errorMessage = string.Empty; // Limpiar mensaje de error cuando se selecciona una ubicación válida
    }

    private async Task OnBlur()
    {
        // Usamos un pequeño delay para permitir que el click en las opciones se procese
        await Task.Delay(150);
        _showDropdown = false;
        StateHasChanged();
    }
}