@page "/libros/crear"
@using LibroManager.Services.Interfaces
@using LibroManager.DTOs
@using LibroManager.Models
@inject ILibroService LibroService
@inject IAutorService AutorService
@inject ICategoriaService CategoriaService
@inject IUbicacionService UbicacionService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Crear Libro - LibroManager</PageTitle>

<div class="container">
    <h1>Crear Nuevo Libro</h1>

    <EditForm Model="@libroDto" OnValidSubmit="@HandleValidSubmit">
        <DataAnnotationsValidator />

        <div class="mb-3">
            <label for="titulo" class="form-label">Título</label>
            <InputText id="titulo" class="form-control" @bind-Value="@libroDto.Titulo" />
            <ValidationMessage For="@(() => libroDto.Titulo)" />
        </div>

        <div class="mb-3">
            <label for="isbn" class="form-label">ISBN</label>
            <InputText id="isbn" class="form-control" @bind-Value="@libroDto.ISBN" />
            <ValidationMessage For="@(() => libroDto.ISBN)" />
        </div>

        <div class="mb-3">
            <label for="autor" class="form-label">Autor</label>
            <InputSelect id="autor" class="form-select" @bind-Value="@libroDto.AutorId">
                <option value="0">Seleccione un autor...</option>
                @if (_autores != null)
                {
                    @foreach (var autor in _autores)
                    {
                        <option value="@autor.AutorId">@autor.Nombre</option>
                    }
                }
            </InputSelect>
            <ValidationMessage For="@(() => libroDto.AutorId)" />
        </div>

        <div class="mb-3">
            <label for="categoria" class="form-label">Categoría</label>
            <InputSelect id="categoria" class="form-select" @bind-Value="@libroDto.CategoriaId">
                <option value="0">Seleccione una categoría...</option>
                @if (_categorias != null)
                {
                    @foreach (var categoria in _categorias)
                    {
                        <option value="@categoria.CategoriaId">@categoria.Nombre</option>
                    }
                }
            </InputSelect>
            <ValidationMessage For="@(() => libroDto.CategoriaId)" />
        </div>

        <div class="mb-3">
            <label for="ubicacion" class="form-label">Ubicación</label>
            <div class="input-group">
                <input type="text" 
                       class="form-control" 
                       id="ubicacion"
                       @bind-value="@searchUbicacion" 
                       @bind-value:event="oninput"
                       @onchange="@UbicacionChanged"
                       @onfocusin="@LoadUbicaciones"
                       placeholder="Buscar ubicación..."
                       list="ubicacionesList" />
                <datalist id="ubicacionesList">
                    @if (_ubicaciones != null && _ubicaciones.Any())
                    {
                        @foreach (var ubicacion in _ubicacionesFiltradas)
                        {
                            <option value="@ubicacion.UbicacionFormateada">
                                @ubicacion.UbicacionFormateada
                            </option>
                        }
                    }
                    else if (_ubicaciones != null)
                    {
                        <option value="">No hay ubicaciones disponibles</option>
                    }
                </datalist>
            </div>
            @if (_ubicaciones != null && !_ubicaciones.Any())
            {
                <div class="alert alert-warning mt-2">
                    No hay ubicaciones disponibles. Por favor, libere alguna ubicación antes de agregar un nuevo libro.
                </div>
            }
            else
            {
                <small class="form-text text-muted">Formato: Estante(A-Z)-Nivel(1-10)-Posición(1-50)</small>
            }
            <ValidationMessage For="@(() => libroDto.UbicacionString)" />
        </div>

        <div class="mb-3">
            <button type="submit" class="btn btn-primary me-2">Guardar</button>
            <button type="button" class="btn btn-secondary" @onclick="@(() => Cancelar())">Cancelar</button>
        </div>
    </EditForm>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger mt-3">
            @_errorMessage
        </div>
    }
</div>

@code {
    private readonly LibroCreateDTO libroDto = new();
    private IEnumerable<AutorDTO>? _autores;
    private IEnumerable<CategoriaDTO>? _categorias;
    private IEnumerable<UbicacionDTO>? _ubicaciones;
    private IEnumerable<UbicacionDTO> _ubicacionesFiltradas => _ubicaciones?
        .Where(u => string.IsNullOrEmpty(searchUbicacion) || 
                    u.UbicacionFormateada.Contains(searchUbicacion, StringComparison.OrdinalIgnoreCase))
        ?? Enumerable.Empty<UbicacionDTO>();
    private string searchUbicacion = "";
    private string _errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        _autores = await AutorService.GetAllAsync();
        _categorias = await CategoriaService.GetAllAsync();
        await LoadUbicaciones();
    }

    private async Task LoadUbicaciones()
    {
        if (_ubicaciones == null)
        {
            _ubicaciones = await UbicacionService.GetAvailableUbicacionesAsync();
        }
    }

    private async Task HandleValidSubmit()
    {
        try
        {
            if (await LibroService.ExisteIsbnAsync(libroDto.ISBN))
            {
                _errorMessage = "Ya existe un libro con este ISBN.";
                return;
            }

            var result = await LibroService.CreateLibroAsync(libroDto);
            if (result)
            {
                NavigationManager.NavigateTo("/libros");
            }
            else
            {
                _errorMessage = "No se pudo crear el libro. Por favor, verifique que la ubicación sea válida e intente nuevamente.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error al crear el libro: {ex.Message}";
        }
    }

    private void Cancelar()
    {
        NavigationManager.NavigateTo("/libros");
    }

    private void UbicacionChanged(ChangeEventArgs e)
    {
        if (e.Value is string ubicacionSeleccionada)
        {
            libroDto.UbicacionString = ubicacionSeleccionada;
            searchUbicacion = ubicacionSeleccionada;
        }
    }
}