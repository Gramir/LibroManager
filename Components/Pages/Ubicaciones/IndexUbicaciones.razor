@page "/ubicaciones"
@using Microsoft.AspNetCore.Authorization
@using LibroManager.DTOs
@using LibroManager.Services.Interfaces
@using Microsoft.AspNetCore.Components.Web
@using LibroManager.Constants
@inject IUbicacionService UbicacionService
@inject NavigationManager NavigationManager
@attribute [Authorize(Policy = RoleConstants.Permissions.Ubicaciones.Read)]
@rendermode InteractiveServer

<PageTitle>Ubicaciones - LibroManager</PageTitle>
<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<div class="ma-4" style="height: calc(100vh - 140px); display: flex; flex-direction: column;">
    <div class="d-flex justify-space-between align-center mb-4">
        <MudText Typo="Typo.h4">Catálogo de Ubicaciones</MudText>
        <AuthorizeView Policy="@RoleConstants.Permissions.Ubicaciones.Create">
            <Authorized>
                <MudButton Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" OnClick="@(() => NavigationManager.NavigateTo("/ubicaciones/crear"))">
                    Nueva Ubicación
                </MudButton>
            </Authorized>
        </AuthorizeView>
    </div>

    @if (_ubicaciones == null)
    {
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    }
    else
    {
        <MudTable Items="@_ubicaciones" Dense="true" Hover="true" Filter="FiltrarUbicaciones"
                  T="UbicacionDTO" Elevation="0" Class="flex-grow-1" FixedHeader="true">
            <ToolBarContent>
                <MudTextField @bind-Value="_searchString" Placeholder="Buscar..." Adornment="Adornment.Start"
                            AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" Immediate="true"></MudTextField>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel T="UbicacionDTO" SortBy="x => x.UbicacionFormateada">Ubicación</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel T="UbicacionDTO" SortBy="x => x.Estante">Estante</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel T="UbicacionDTO" SortBy="x => x.Nivel">Nivel</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel T="UbicacionDTO" SortBy="x => x.Posicion">Posición</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel T="UbicacionDTO" SortBy="x => x.EstaDisponible">Estado</MudTableSortLabel></MudTh>
                <MudTh>Acciones</MudTh>
            </HeaderContent>
            <RowTemplate Context="ubicacion">
                <MudTd DataLabel="Ubicación">@ubicacion.UbicacionFormateada</MudTd>
                <MudTd DataLabel="Estante">@ubicacion.Estante</MudTd>
                <MudTd DataLabel="Nivel">@ubicacion.Nivel</MudTd>
                <MudTd DataLabel="Posición">@ubicacion.Posicion</MudTd>
                <MudTd DataLabel="Estado">
                    <MudChip T="string" Variant="Variant.Filled" Color="@(ubicacion.EstaDisponible ? Color.Success : Color.Warning)" Size="Size.Small">
                        @(ubicacion.EstaDisponible ? "Disponible" : "Ocupada")
                    </MudChip>
                </MudTd>
                <MudTd>
                    <MudStack Row="true" Spacing="1">
                        <AuthorizeView Policy="@RoleConstants.Permissions.Ubicaciones.Read">
                            <Authorized>
                                <MudIconButton Icon="@Icons.Material.Filled.Visibility" Color="Color.Primary" Size="Size.Small"
                                             OnClick="@(() => VerDetalles(ubicacion.UbicacionId))"
                                             aria-label="Ver detalles" />
                            </Authorized>
                        </AuthorizeView>
                        <AuthorizeView Policy="@RoleConstants.Permissions.Ubicaciones.Update">
                            <Authorized>
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Warning" Size="Size.Small"
                                             OnClick="@(() => EditarUbicacion(ubicacion.UbicacionId))"
                                             aria-label="Editar ubicación" />
                            </Authorized>
                        </AuthorizeView>
                    </MudStack>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager RowsPerPageString="Filas por página" />
            </PagerContent>
        </MudTable>
    }
</div>

@code {
    private IEnumerable<UbicacionDTO>? _ubicaciones;
    private string _searchString = "";

    protected override async Task OnInitializedAsync()
    {
        _ubicaciones = await UbicacionService.GetAllUbicacionesAsync();
    }

    private void VerDetalles(int ubicacionId)
    {
        NavigationManager.NavigateTo($"/ubicaciones/{ubicacionId}");
    }

    private void EditarUbicacion(int ubicacionId)
    {
        NavigationManager.NavigateTo($"/ubicaciones/editar/{ubicacionId}");
    }

    private bool FiltrarUbicaciones(UbicacionDTO ubicacion)
    {
        if (string.IsNullOrWhiteSpace(_searchString)) return true;
        return ubicacion.UbicacionFormateada?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) == true
            || ubicacion.Estante.ToString()?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) == true
            || ubicacion.Nivel.ToString()?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) == true
            || ubicacion.Posicion.ToString()?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) == true;
    }
}