@page "/ubicaciones"
@using Microsoft.AspNetCore.Authorization
@using LibroManager.DTOs
@using LibroManager.Services.Interfaces
@using Microsoft.AspNetCore.Components.Web
@using LibroManager.Constants
@inject IUbicacionService UbicacionService
@inject NavigationManager NavigationManager
@attribute [Authorize(Policy = RoleConstants.Permissions.Ubicaciones.Read)]
@rendermode InteractiveServer
<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<PageTitle>Ubicaciones - LibroManager</PageTitle>

<h1>Ubicaciones</h1>

<AuthorizeView Roles="@RoleConstants.AdminRole">
    <Authorized>
        <div class="mb-3">
            <a href="/ubicaciones/crear" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Nueva Ubicación
            </a>
        </div>
    </Authorized>
</AuthorizeView>

@if (_ubicaciones == null)
{
    <div class="d-flex justify-content-center">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Cargando...</span>
        </div>
    </div>
}
else if (!_ubicaciones.Any())
{
    <div class="alert alert-info" role="alert">
        No hay ubicaciones registradas.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Ubicación</th>
                    <th>Estante</th>
                    <th>Nivel</th>
                    <th>Posición</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ubicacion in _ubicaciones)
                {
                    <tr>
                        <td>@ubicacion.UbicacionFormateada</td>
                        <td>@ubicacion.Estante</td>
                        <td>@ubicacion.Nivel</td>
                        <td>@ubicacion.Posicion</td>
                        <td>
                            <span class="badge @(ubicacion.EstaDisponible ? "bg-success" : "bg-warning")">
                                @(ubicacion.EstaDisponible ? "Disponible" : "Ocupada")
                            </span>
                        </td>
                        <td>
                            <AuthorizeView Policy="@RoleConstants.Permissions.Ubicaciones.Read">
                                <Authorized>
                                    <button class="btn btn-primary btn-sm me-2" @onclick="() => VerDetalles(ubicacion.UbicacionId)">
                                        <i class="bi bi-eye"></i> Detalles
                                    </button>
                                </Authorized>
                            </AuthorizeView>
                            <AuthorizeView Roles="@RoleConstants.AdminRole">
                                <Authorized>
                                    <button class="btn btn-warning btn-sm me-2" @onclick="() => EditarUbicacion(ubicacion.UbicacionId)">
                                        <i class="bi bi-pencil"></i> Editar
                                    </button>
                                </Authorized>
                            </AuthorizeView>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private IEnumerable<UbicacionDTO>? _ubicaciones;

    protected override async Task OnInitializedAsync()
    {
        _ubicaciones = await UbicacionService.GetAllUbicacionesAsync();
    }

    private void VerDetalles(int ubicacionId)
    {
        NavigationManager.NavigateTo($"/ubicaciones/{ubicacionId}");
    }

    private void EditarUbicacion(int ubicacionId)
    {
        NavigationManager.NavigateTo($"/ubicaciones/editar/{ubicacionId}");
    }
}