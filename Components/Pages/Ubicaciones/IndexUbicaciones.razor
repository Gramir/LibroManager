@page "/ubicaciones"
@using LibroManager.DTOs
@using LibroManager.Services.Interfaces
@using Microsoft.AspNetCore.Components.Web
@inject IUbicacionService UbicacionService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Ubicaciones - LibroManager</PageTitle>

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Ubicaciones</h1>
        <a href="/ubicaciones/crear" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Nueva Ubicación
        </a>
    </div>

    @if (_ubicaciones == null)
    {
        <div class="d-flex justify-content-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    }
    else if (!_ubicaciones.Any())
    {
        <div class="alert alert-info" role="alert">
            No hay ubicaciones registradas.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Ubicación</th>
                        <th>Estante</th>
                        <th>Nivel</th>
                        <th>Posición</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ubicacion in _ubicaciones)
                    {
                        <tr>
                            <td>@ubicacion.UbicacionFormateada</td>
                            <td>@ubicacion.Estante</td>
                            <td>@ubicacion.Nivel</td>
                            <td>@ubicacion.Posicion</td>
                            <td>
                                <span class="badge @(ubicacion.EstaDisponible ? "bg-success" : "bg-warning")">
                                    @(ubicacion.EstaDisponible ? "Disponible" : "Ocupada")
                                </span>
                            </td>
                            <td>
                                <a href="/ubicaciones/@ubicacion.UbicacionId" class="btn btn-primary btn-sm me-2">
                                    <i class="bi bi-eye"></i> Detalles
                                </a>
                                <a href="/ubicaciones/editar/@ubicacion.UbicacionId" class="btn btn-warning btn-sm">
                                    <i class="bi bi-pencil"></i> Editar
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private IEnumerable<UbicacionDTO>? _ubicaciones;

    protected override async Task OnInitializedAsync()
    {
        _ubicaciones = await UbicacionService.GetAllUbicacionesAsync();
    }
}