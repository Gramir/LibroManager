@page "/categorias"
@using Microsoft.AspNetCore.Authorization
@using LibroManager.Services.Interfaces
@using LibroManager.DTOs
@using LibroManager.Constants
@inject ICategoriaService CategoriaService
@inject NavigationManager NavigationManager
@attribute [Authorize(Policy = RoleConstants.Permissions.Categorias.Read)]
@rendermode InteractiveServer

<PageTitle>Categorías - LibroManager</PageTitle>

<h1>Categorías</h1>

<AuthorizeView Roles="@RoleConstants.AdminRole">
    <Authorized>
        <div class="mb-3">
            <a href="/categorias/crear" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Nueva Categoría
            </a>
        </div>
    </Authorized>
</AuthorizeView>

@if (_categorias == null)
{
    <div class="d-flex justify-content-center">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Cargando...</span>
        </div>
    </div>
}
else if (!_categorias.Any())
{
    <div class="alert alert-info" role="alert">
        No hay categorías registradas.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Libros Asociados</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var categoria in _categorias)
                {
                    <tr>
                        <td>@categoria.Nombre</td>
                        <td>@categoria.CantidadLibros</td>
                        <td>
                            <AuthorizeView Policy="@RoleConstants.Permissions.Categorias.Read">
                                <Authorized>
                                    <button class="btn btn-primary btn-sm me-2" @onclick="() => VerDetalles(categoria.CategoriaId)">
                                        <i class="bi bi-eye"></i> Detalles
                                    </button>
                                </Authorized>
                            </AuthorizeView>
                            <AuthorizeView Roles="@RoleConstants.AdminRole">
                                <Authorized>
                                    <button class="btn btn-warning btn-sm me-2" @onclick="() => EditarCategoria(categoria.CategoriaId)">
                                        <i class="bi bi-pencil"></i> Editar
                                    </button>
                                </Authorized>
                            </AuthorizeView>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private IEnumerable<CategoriaDTO>? _categorias;

    protected override async Task OnInitializedAsync()
    {
        _categorias = await CategoriaService.GetCategoriasWithLibrosAsync();
    }

    private void VerDetalles(int categoriaId)
    {
        NavigationManager.NavigateTo($"/categorias/{categoriaId}");
    }

    private void EditarCategoria(int categoriaId)
    {
        NavigationManager.NavigateTo($"/categorias/editar/{categoriaId}");
    }
}