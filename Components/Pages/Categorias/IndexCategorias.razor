@page "/categorias"
@using LibroManager.Services.Interfaces
@using LibroManager.DTOs
@inject ICategoriaService CategoriaService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Categorías - LibroManager</PageTitle>

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Categorías</h1>
        <a href="/categorias/crear" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Nueva Categoría
        </a>
    </div>

    @if (_categorias == null)
    {
        <div class="d-flex justify-content-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    }
    else if (!_categorias.Any())
    {
        <div class="alert alert-info" role="alert">
            No hay categorías registradas.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Cantidad de Libros</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var categoria in _categorias)
                    {
                        <tr>
                            <td>@categoria.Nombre</td>
                            <td>@categoria.CantidadLibros</td>
                            <td>
                                <button class="btn btn-primary btn-sm me-1" @onclick="() => VerDetalles(categoria.CategoriaId)">
                                    <i class="bi bi-eye"></i> Detalles
                                </button>
                                <button class="btn btn-warning btn-sm" @onclick="() => EditarCategoria(categoria.CategoriaId)">
                                    <i class="bi bi-pencil"></i> Editar
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private IEnumerable<CategoriaDTO>? _categorias;

    protected override async Task OnInitializedAsync()
    {
        _categorias = await CategoriaService.GetCategoriasWithLibrosAsync();
    }

    private void VerDetalles(int categoriaId)
    {
        NavigationManager.NavigateTo($"/categorias/{categoriaId}");
    }

    private void EditarCategoria(int categoriaId)
    {
        NavigationManager.NavigateTo($"/categorias/editar/{categoriaId}");
    }
}