@page "/Account/ResetPasswordConfirmation"

<PageTitle>Confirmación de Cambio - LibroManager</PageTitle>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-body text-center">
                    <h3 class="card-title mb-4">¡Contraseña Restablecida!</h3>
